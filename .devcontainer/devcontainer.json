{
  "name": "notdefined",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "runArgs": ["--name", "notdefined"],
  "forwardPorts": [4321],
  "portsAttributes": {
    "4321": {
      "label": "Astro Dev Server",
      "onAutoForward": "notify"
    }
  },
  "mounts": [
    "source=notdefined-bashhistory,target=/commandhistory,type=volume",
    "source=notdefined-npmcache,target=/home/node/.npm,type=volume",
    "source=notdefined-rubygems,target=/usr/local/rvm/gems,type=volume"
  ],
  "postCreateCommand": "npm install && gem install bundler",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {},
    "ghcr.io/devcontainers/features/ruby:1": {
      "version": "3.4"
    },
    "ghcr.io/stuartleeks/dev-container-features/shell-history:0": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "bradlc.vscode-tailwindcss",
        "shopify.ruby-lsp",
        "anthropic.claude-code"
      ]
    }
  }
}
