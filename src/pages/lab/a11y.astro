        0.317922, 0.680742,
      ],
      [
        1.193214, -0.109812, -0.083402, -0.058496, 0.97941, 0.079086, -0.002346,
        0.403492, 0.598854,
      ],
      [
        1.257728, -0.139648, -0.118081, -0.078003, 0.975409, 0.102594,
        -0.003316, 0.501214, 0.502102,
      ],
      [
        1.278864, -0.125333, -0.153531, -0.084748, 0.957674, 0.127074,
        -0.000989, 0.601151, 0.399838,
      ],
      [
        1.255528, -0.076749, -0.178779, -0.078411, 0.930809, 0.147602, 0.004733,
        0.691367, 0.3039,
      ],
    ],
  };

  // El post companion trae un "playground" de ejemplos diseñados para romperse
  // bajo cada condición — mejor demo que el home del blog.
  const POST_URL = '/blog/ver-tu-sitio-con-otros-ojos/';

  type Step = { name: string; level: number };

  const $ = (id: string) => document.getElementById(id)!;
  const start = $('start');
  const sim = $('sim');
  const frame = $('frame') as HTMLIFrameElement;
  const overlay = $('overlay');
  const slider = $('severity') as HTMLInputElement;
  const matrixEl = $('cvd-matrix');
  const drawer = $('drawer');
  const drawerOpen = $('drawer-open') as HTMLButtonElement;
  const drawerClose = $('drawer-close') as HTMLButtonElement;
  const badge = $('badge');
  const stageBlock = $('stage-block');
  const stageName = $('stage-name');
  const stageTicks = $('stage-ticks');
  const prevalenceEl = $('prevalence');
  const scaleEl = $('scale');
  const blindEl = $('blind');
  const blindUnavailable = $('blind-unavailable');
  const blindReader = $('blind-reader');
  const blindCaption = $('blind-caption');

  let type = 'none';
  let label = 'Visión típica';
  let steps: Step[] = [];

  // Lector de pantalla casero (modo "Sin visión"). Solo mismo origen: la SOP
  // sella el DOM de un iframe cross-origin, así que solo puede leer este sitio.
  let readerActive = false;
  let flow: HTMLElement[] = [];
  let headings: HTMLElement[] = [];
  let links: HTMLElement[] = [];
  let cur: HTMLElement | null = null;
  let flowIndex = 0;
  let voice: SpeechSynthesisVoice | null = null;

  function pickVoice() {
    if (!('speechSynthesis' in window)) return;
    const vs = speechSynthesis.getVoices();
    voice =
      vs.find((v) => /es[-_]MX/i.test(v.lang)) ||
      vs.find((v) => /^es/i.test(v.lang)) ||
      null;
  }
  pickVoice();
  if ('speechSynthesis' in window) speechSynthesis.onvoiceschanged = pickVoice;

  function speak(text: string) {
    blindCaption.textContent = text;
    if (!('speechSynthesis' in window)) return;
    const u = new SpeechSynthesisUtterance(text);
    u.lang = 'es-MX';
    if (voice) u.voice = voice;
    speechSynthesis.cancel();
    speechSynthesis.speak(u);
  }

  function getFrameDoc(): Document | null {
    try {
      const d = frame.contentDocument;
      if (!d || !d.body) return null;
      void d.body.tagName;
      return d;
    } catch {
      return null;
    }
  }

  function readText(el: HTMLElement) {
    if (el.tagName === 'IMG') return (el.getAttribute('alt') || '').trim();
    return (el.innerText || el.textContent || '')
      .replace(/\s+/g, ' ')
      .trim()
      .slice(0, 300);
  }

  function usable(el: HTMLElement) {
    if (!readText(el)) return false;
    return el.offsetParent !== null || el.getClientRects().length > 0;
  }

  function describe(el: HTMLElement) {
    const tag = el.tagName.toLowerCase();
    if (tag === 'img')
      return `imagen: ${el.getAttribute('alt') || 'sin descripción'}`;
    const text = readText(el);
    if (/^h[1-6]$/.test(tag)) return `encabezado nivel ${tag[1]}: ${text}`;
    if (tag === 'a') return `enlace: ${text}`;
    if (tag === 'button') return `botón: ${text}`;
    if (tag === 'li') return `viñeta: ${text}`;
    return text;
  }

  function buildNodes(doc: Document) {
    flow = Array.from(
      doc.querySelectorAll<HTMLElement>(
        'h1,h2,h3,h4,h5,h6,p,li,button,img[alt]',
      ),
    ).filter(usable);
    headings = flow.filter((el) => /^h[1-6]$/i.test(el.tagName));
    links = Array.from(doc.querySelectorAll<HTMLElement>('a[href]')).filter(
      usable,
    );
  }

  function setCur(el: HTMLElement) {
    cur = el;
    const i = flow.indexOf(el);
    if (i >= 0) flowIndex = i;
    speak(describe(el));
  }

  function move(dir: number) {
    if (!flow.length) return;
    flowIndex = Math.max(0, Math.min(flow.length - 1, flowIndex + dir));
    setCur(flow[flowIndex]);
  }

  function relative(list: HTMLElement[], dir: number): HTMLElement | null {
    if (!cur) return list[0] ?? null;
    if (dir > 0) {
      for (const el of list) {
        if (
          el !== cur &&
          cur.compareDocumentPosition(el) & Node.DOCUMENT_POSITION_FOLLOWING
        )
          return el;
      }
      return null;
    }
    let last: HTMLElement | null = null;
    for (const el of list) {
      if (
        el !== cur &&
        cur.compareDocumentPosition(el) & Node.DOCUMENT_POSITION_PRECEDING
      )
        last = el;
    }
    return last;
  }

  function activateCur() {
    if (!cur) return;
    if (cur.tagName === 'A') {
      const href = (cur as HTMLAnchorElement).href;
      speak('Abriendo enlace');
      const doc = getFrameDoc();
      if (doc && doc.defaultView) doc.defaultView.location.href = href;
      else frame.src = href;
    } else if (cur.tagName === 'BUTTON') {
      speak('Botón — desactivado en el lector');
    }
  }

  function handleReaderKey(e: KeyboardEvent): boolean {
    const k = e.key;
    if (k === 'ArrowDown' || k === 'ArrowRight') {
      e.preventDefault();
      move(1);
      return true;
    }
    if (k === 'ArrowUp' || k === 'ArrowLeft') {
      e.preventDefault();
      move(-1);
      return true;
    }
    if (k === 'h' || k === 'H') {
      e.preventDefault();
      const el = relative(headings, e.shiftKey ? -1 : 1);
      if (el) setCur(el);
      else speak('No hay más encabezados');
      return true;
    }
    if (k === 'k' || k === 'K') {
      e.preventDefault();
      const el = relative(links, e.shiftKey ? -1 : 1);
      if (el) setCur(el);
      else speak('No hay más enlaces');
      return true;
    }
    if (k === 'Enter') {
      e.preventDefault();
      activateCur();
      return true;
    }
    if (k === 'Home') {
      e.preventDefault();
      if (flow[0]) setCur(flow[0]);
      return true;
    }
    if (k === 'End') {
      e.preventDefault();
      if (flow.length) setCur(flow[flow.length - 1]);
      return true;
    }
    return false;
  }

  function activateBlind() {
    readerActive = true;
    blindEl.hidden = false;
    const doc = getFrameDoc();
    if (!doc) {
      blindUnavailable.hidden = false;
      blindReader.hidden = true;
      if ('speechSynthesis' in window) speechSynthesis.cancel();
      return;
    }
    blindUnavailable.hidden = true;
    blindReader.hidden = false;
    buildNodes(doc);
    cur = flow[0] ?? null;
    flowIndex = 0;
    if (cur) speak(describe(cur));
    else speak('No encontré contenido legible en esta página.');
  }

  function deactivateBlind() {
    if (!readerActive) return;
    readerActive = false;
    blindEl.hidden = true;
    if ('speechSynthesis' in window) speechSynthesis.cancel();
  }

  function renderMatrix(cvdKey: string, level: number) {
    const m = MACHADO[cvdKey][Math.round(level * 10)];
    matrixEl.setAttribute(
      'values',
      `${m[0]} ${m[1]} ${m[2]} 0 0 ` +
        `${m[3]} ${m[4]} ${m[5]} 0 0 ` +
        `${m[6]} ${m[7]} ${m[8]} 0 0 ` +
        `0 0 0 1 0`,
    );
    frame.style.filter = 'url(#cvd)';
  }

  function apply() {
    frame.style.filter = '';
    overlay.style.background = '';

    if (type === 'none' || steps.length === 0) {
      badge.textContent = label;
      return;
    }

    const step = steps[Number(slider.value) - 1];
    const lvl = step.level;

    if (MACHADO[type]) {
      renderMatrix(type, lvl);
    } else if (type === 'blur') {
      frame.style.filter = `blur(${(lvl * 6).toFixed(1)}px)`;
    } else if (type === 'cataract') {
      frame.style.filter =
        `blur(${(lvl * 2.5).toFixed(1)}px) sepia(${(lvl * 0.45).toFixed(2)}) ` +
        `brightness(${(1 + lvl * 0.12).toFixed(2)}) contrast(${(1 - lvl * 0.3).toFixed(2)})`;
    } else if (type === 'tunnel') {
      // El glaucoma no es un túnel negro nítido: borde difuso + leve blur.
      const clear = 55 - lvl * 45;
      overlay.style.background = `radial-gradient(circle at 50% 45%, transparent ${clear}%, rgba(0,0,0,0.75) ${clear + 12}%, #000 ${clear + 26}%)`;
      frame.style.filter = `blur(${(lvl * 1.2).toFixed(1)}px)`;
    } else if (type === 'macular') {
      const spot = 5 + lvl * 25;
      overlay.style.background = `radial-gradient(circle at 50% 45%, #000 ${spot}%, transparent ${spot + 12}%)`;
    }

    stageName.textContent = step.name;
    badge.textContent = `${label} · ${step.name}`;
  }

  function paintTicks() {
    stageTicks.innerHTML = '';
    steps.forEach((s, i) => {
      const t = document.createElement('span');
      t.textContent = String(i + 1);
      t.title = s.name;
      stageTicks.appendChild(t);
    });
  }

  const radios = Array.from(
    document.querySelectorAll<HTMLInputElement>('input[name="condition"]'),
  );

  function selectCondition(radio: HTMLInputElement) {
    type = radio.dataset.type ?? 'none';
    label = radio.dataset.label ?? '';
    steps = JSON.parse(radio.dataset.steps || '[]');
    $('blurb').textContent = radio.dataset.blurb ?? '';

    const hasSteps = steps.length > 0;
    stageBlock.hidden = !hasSteps;
    if (hasSteps) {
      slider.max = String(steps.length);
      slider.value = String(steps.length); // arranca en el estadio más severo
      paintTicks();
    }

    const prev = radio.dataset.prevalence ?? '';
    prevalenceEl.hidden = !prev;
    prevalenceEl.textContent = prev;
    const scale = radio.dataset.scale ?? '';
    scaleEl.hidden = !scale;
    scaleEl.textContent = scale;

    if (type === 'blind') {
      frame.style.filter = '';
      overlay.style.background = '';
      badge.textContent = label;
      activateBlind();
      return;
    }
    deactivateBlind();
    apply();
  }

  radios.forEach((radio) => {
    radio.addEventListener('change', () => selectCondition(radio));
  });

  slider.addEventListener('input', apply);

  function setDrawer(open: boolean, moveFocus = true) {
    drawer.hidden = !open;
    drawerOpen.hidden = open;
    drawerOpen.setAttribute('aria-expanded', String(open));
    drawerClose.setAttribute('aria-expanded', String(open));
    if (moveFocus) (open ? drawerClose : drawerOpen).focus();
  }

  drawerOpen.addEventListener('click', () => setDrawer(true));
  drawerClose.addEventListener('click', () => setDrawer(false));

  let frameLoaded = false;

  function showSim() {
    if (!frameLoaded) {
      frame.src = POST_URL;
      frameLoaded = true;
    }
    start.hidden = true;
    sim.hidden = false;
    setDrawer(true);
  }

  function showStart() {
    sim.hidden = true;
    start.hidden = false;
    $('begin').focus();
  }

  // Entrar empuja un estado al historial para que el botón back del navegador
  // regrese a la portada en vez de abandonar la página.
  $('begin').addEventListener('click', () => {
    history.pushState({ sim: true }, '', '#sim');
    showSim();
  });

  function exitSim() {
    deactivateBlind();
    if (history.state?.sim) {
      history.back();
    } else {
      showStart();
    }
  }

  $('exit').addEventListener('click', exitSim);

  window.addEventListener('popstate', () => {
    if (!history.state?.sim) showStart();
  });

  if (location.hash === '#sim') {
    history.replaceState(null, '', location.pathname);
  }

  $('url-form').addEventListener('submit', (e) => {
    e.preventDefault();
    const input = $('url') as HTMLInputElement;
    const raw = input.value.trim();
    if (!raw) return;
    const url = /^https?:\/\//i.test(raw) ? raw : `https://${raw}`;
    input.value = url;
    frame.src = url;
  });

  $('reset-url').addEventListener('click', () => {
    ($('url') as HTMLInputElement).value = '';
    frame.src = POST_URL;
  });

  $('blind-load-post').addEventListener('click', () => {
    frame.src = POST_URL;
  });

  // Al recargar el iframe (navegar un enlace, o cargar el post desde el modo sin
  // visión), reconstruye el árbol de nodos y sigue leyendo desde arriba.
  frame.addEventListener('load', () => {
    if (!readerActive) return;
    const doc = getFrameDoc();
    if (!doc) {
      blindUnavailable.hidden = false;
      blindReader.hidden = true;
      return;
    }
    blindUnavailable.hidden = true;
    blindReader.hidden = false;
    buildNodes(doc);
    cur = flow[0] ?? null;
    flowIndex = 0;
    if (cur) speak(describe(cur));
  });

  window.addEventListener('keydown', (e) => {
    if (sim.hidden) return;
    const target = e.target as HTMLElement | null;
    // Solo los campos de texto tragan las teclas; radios/botones/slider no, para
    // que las flechas y H/K del lector funcionen aunque el foco quede en ellos.
    const textEntry =
      !!target &&
      ((target.tagName === 'INPUT' &&
        !['radio', 'checkbox', 'range', 'button', 'submit'].includes(
          (target as HTMLInputElement).type,
        )) ||
        target.tagName === 'TEXTAREA' ||
        target.isContentEditable);

    if (e.key === 'Escape') {
      exitSim();
      return;
    }
    if (textEntry) return;
    if (e.key === 'c') {
      setDrawer(drawer.hidden);
      return;
    }
    if (readerActive && handleReaderKey(e)) return;
    const n = Number(e.key);
    if (n >= 1 && n <= radios.length) {
      const radio = radios[n - 1];
      radio.checked = true;
      selectCondition(radio);
    }
  });

  apply();
</script>

