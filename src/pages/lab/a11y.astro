      ],
      [
        0.367322, 0.860646, -0.227968, 0.280085, 0.672501, 0.047413, -0.01182,
        0.04294, 0.968881,
      ],
    ],
    tritan: [
      IDENTITY,
      [
        0.92667, 0.092514, -0.019184, 0.021191, 0.964503, 0.014306, 0.008437,
        0.054813, 0.93675,
