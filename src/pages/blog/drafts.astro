---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CardList from '../../components/CardList.astro';
import TagPill from '../../components/TagPill.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { readingTime } from '../../utils/reading-time';

const drafts = (
  await getCollection('blog', ({ data }) => data.draft === true)
).sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', { month: 'short', day: 'numeric' });
}
---

<BaseLayout
  title="Drafts — notdefined.dev"
  description="Borradores en progreso."
>
  <PageHeader
    label="Escritura"
    title="Drafts"
    description="Borradores en progreso. Esta página no aparece en la navegación del sitio."
  >
    <div slot="actions" class="header-actions">
      <a href="/blog/" class="action-link">← Volver al blog</a>
    </div>
  </PageHeader>

  {
    drafts.length === 0 ? (
      <p class="empty">No hay borradores por ahora.</p>
    ) : (
      <CardList>
        {drafts.map((post) => (
          <li class="card-list-item">
            <a href={`/blog/${post.slug}/`} class="post-link">
              <div class="post-header-row">
                <span class="draft-badge">DRAFT</span>
                <h3 class="post-title">{post.data.title}</h3>
              </div>
              <p class="post-desc">{post.data.description}</p>
              <div class="post-footer">
                <div class="tag-row">
                  {post.data.tags.map((tag: string) => (
                    <TagPill label={tag} />
                  ))}
                </div>
                <span class="post-meta">
                  {formatDate(post.data.pubDate)} · {readingTime(post.body)} min
                </span>
              </div>
            </a>
          </li>
        ))}
      </CardList>
    )
  }
</BaseLayout>

<style>
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .action-link {
    font-size: 0.85rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 150ms ease;
  }
  .action-link:hover {
    opacity: 0.7;
  }

  .empty {
    font-size: 0.9rem;
    color: var(--color-muted);
    padding: 2rem 0;
  }

  .post-link {
    display: block;
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: background-color 120ms ease;
  }
  .post-link:hover {
    background-color: var(--color-surface);
  }

  .post-header-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .draft-badge {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.15em 0.45em;
    border-radius: 0.25rem;
    background-color: #f59e0b;
    color: #000;
    flex-shrink: 0;
  }

  .post-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    margin: 0;
    transition: color 120ms ease;
  }
  .post-link:hover .post-title {
    color: var(--color-accent);
  }

  .post-desc {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0 0 0.625rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    min-width: 0;
  }

  .post-meta {
    font-size: 0.72rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0.8;
  }
</style>
