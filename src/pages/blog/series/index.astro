---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import CardList from '../../../components/CardList.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const posts = await getCollection(
  'blog',
  ({ data }) => !data.draft && !!data.series,
);

const seriesMap = new Map<string, CollectionEntry<'blog'>[]>();
for (const post of posts) {
  const series = post.data.series!;
  if (!seriesMap.has(series)) seriesMap.set(series, []);
  seriesMap.get(series)!.push(post);
}

const seriesList = [...seriesMap.entries()]
  .map(([name, seriesPosts]) => ({
    name,
    posts: seriesPosts.sort(
      (a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0),
    ),
  }))
  .sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout
  title="Series — notdefined.dev"
  description="Colecciones de posts relacionados en notdefined.dev."
>
  <PageHeader
    backHref="/blog/"
    backLabel="← Blog"
    label="Colecciones"
    title="Series"
    description="Posts agrupados por tema en orden de lectura."
  />

  {
    seriesList.length === 0 ? (
      <p class="empty">No hay series todavía.</p>
    ) : (
      <CardList>
        {seriesList.map(({ name, posts }) => (
          <div class="card-list-item series-item">
            <a
              href={`/blog/series/${encodeURIComponent(name)}/`}
              class="series-name"
            >
              {name}
            </a>
            <span class="series-count">
              {posts.length} parte{posts.length !== 1 ? 's' : ''}
            </span>
          </div>
        ))}
      </CardList>
    )
  }
</BaseLayout>

<style>
  .empty {
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .series-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
  }

  .series-name {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .series-name:hover {
    color: var(--color-accent);
  }

  .series-count {
    font-size: 0.8rem;
    color: var(--color-muted);
    flex-shrink: 0;
  }
</style>
