---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import CardList from '../../../components/CardList.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { readingTime } from '../../../utils/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection(
    'blog',
    ({ data }) => !data.draft && !!data.series,
  );

  const seriesMap = new Map<string, CollectionEntry<'blog'>[]>();
  for (const post of posts) {
    const series = post.data.series!;
    if (!seriesMap.has(series)) seriesMap.set(series, []);
    seriesMap.get(series)!.push(post);
  }

  return [...seriesMap.entries()].map(([series, seriesPosts]) => ({
    params: { series },
    props: {
      series,
      posts: seriesPosts.sort(
        (a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0),
      ),
    },
  }));
}

const { series, posts } = Astro.props as {
  series: string;
  posts: CollectionEntry<'blog'>[];
};

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={`${series} — notdefined.dev`}
  description={`Serie "${series}" en notdefined.dev (${posts.length} partes).`}
>
  <PageHeader
    backHref="/blog/series/"
    backLabel="← Todas las series"
    label="Series"
    title={series}
    description={`${posts.length} parte${posts.length !== 1 ? 's' : ''} · En orden de lectura`}
  />

  <CardList as="ol" class="series-list">
    {
      posts.map((post, i) => (
        <li class="card-list-item">
          <a href={`/blog/${post.slug}/`} class="post-link">
            <span class="part-num">{i + 1}</span>
            <div class="post-meta">
              <span class="post-title">{post.data.title}</span>
              <p class="post-desc">{post.data.description}</p>
            </div>
            <div class="post-right">
              <span class="post-date">{formatDate(post.data.pubDate)}</span>
              <span class="read-time">{readingTime(post.body)} min</span>
            </div>
          </a>
        </li>
      ))
    }
  </CardList>
</BaseLayout>

<style>
  .series-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-link {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    transition: background-color 150ms ease;
    text-decoration: none;
  }
  .post-link:hover {
    background-color: var(--color-surface);
  }

  .part-num {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    opacity: 0.7;
    min-width: 1.25rem;
    padding-top: 0.2rem;
    flex-shrink: 0;
  }

  .post-meta {
    flex: 1;
    min-width: 0;
  }

  .post-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    display: block;
    margin-bottom: 0.25rem;
  }
  .post-link:hover .post-title {
    color: var(--color-accent);
  }

  .post-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0;
  }

  .post-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    flex-shrink: 0;
    padding-top: 0.15rem;
  }

  .post-date {
    font-size: 0.78rem;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .read-time {
    font-size: 0.72rem;
    color: var(--color-muted);
    white-space: nowrap;
    opacity: 0.7;
  }
</style>
