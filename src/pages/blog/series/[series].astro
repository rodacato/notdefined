---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { readingTime } from '../../../utils/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && !!data.series);

  const seriesMap = new Map<string, CollectionEntry<'blog'>[]>();
  for (const post of posts) {
    const s = post.data.series!;
    if (!seriesMap.has(s)) seriesMap.set(s, []);
    seriesMap.get(s)!.push(post);
  }

  return [...seriesMap.entries()].map(([series, seriesPosts]) => ({
    params: { series },
    props: {
      series,
      posts: seriesPosts.sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0)),
    },
  }));
}

const { series, posts } = Astro.props as { series: string; posts: CollectionEntry<'blog'>[] };

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<BaseLayout
  title={`${series} — notdefined.dev`}
  description={`Serie "${series}" en notdefined.dev — ${posts.length} partes.`}
>

  <header class="mb-10">
    <a href="/blog/series/" class="back-link">← Todas las series</a>
    <p class="label mb-2">Series</p>
    <h1 class="page-title">{series}</h1>
    <p class="page-desc">{posts.length} parte{posts.length !== 1 ? 's' : ''} · En orden de lectura</p>
  </header>

  <ol class="post-list">
    {posts.map((post: CollectionEntry<'blog'>, i: number) => (
      <li class={i > 0 ? 'post-item bordered' : 'post-item'}>
        <a href={`/blog/${post.slug}/`} class="post-link">
          <span class="part-num">{i + 1}</span>
          <div class="post-meta">
            <span class="post-title">{post.data.title}</span>
            <p class="post-desc">{post.data.description}</p>
          </div>
          <div class="post-right">
            <span class="post-date">{formatDate(post.data.pubDate)}</span>
            <span class="read-time">{readingTime(post.body)} min</span>
          </div>
        </a>
      </li>
    ))}
  </ol>

</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 150ms ease;
  }
  .back-link:hover { color: var(--color-accent); }

  .label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .page-title {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  .page-desc {
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .post-list {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-item.bordered { border-top: 1px solid var(--color-border); }
  .post-link {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    transition: background-color 150ms ease;
    text-decoration: none;
  }
  .post-link:hover { background-color: var(--color-surface); }
  .part-num {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    opacity: 0.7;
    min-width: 1.25rem;
    padding-top: 0.2rem;
    flex-shrink: 0;
  }
  .post-meta { flex: 1; min-width: 0; }
  .post-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    display: block;
    margin-bottom: 0.25rem;
  }
  .post-link:hover .post-title { color: var(--color-accent); }
  .post-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0;
  }
  .post-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    flex-shrink: 0;
    padding-top: 0.15rem;
  }
  .post-date {
    font-size: 0.78rem;
    color: var(--color-muted);
    white-space: nowrap;
  }
  .read-time {
    font-size: 0.72rem;
    color: var(--color-muted);
    white-space: nowrap;
    opacity: 0.7;
  }
</style>
