---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readingTime } from '../../utils/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props as {
  post: CollectionEntry<'blog'>;
  allPosts: CollectionEntry<'blog'>[];
};
const { Content } = await render(post);
const mins = readingTime(post.body);

// Related posts: ranked by shared tags, excluding current post
const related = allPosts
  .filter((p) => p.slug !== post.slug)
  .map((p) => ({
    post: p,
    shared: p.data.tags.filter((t: string) => post.data.tags.includes(t)).length,
  }))
  .filter(({ shared }) => shared > 0)
  .sort((a, b) => b.shared - a.shared || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 3)
  .map(({ post }) => post);

// Series navigation
let seriesPosts: CollectionEntry<'blog'>[] = [];
let seriesIndex = -1;
if (post.data.series) {
  seriesPosts = allPosts
    .filter((p) => p.data.series === post.data.series)
    .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
  seriesIndex = seriesPosts.findIndex((p) => p.slug === post.slug);
}
const prevInSeries = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : null;
const nextInSeries = seriesIndex >= 0 && seriesIndex < seriesPosts.length - 1 ? seriesPosts[seriesIndex + 1] : null;

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' });
}

function formatDateShort(date: Date) {
  return date.toLocaleDateString('es-MX', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<BaseLayout title={`${post.data.title} — notdefined.dev`} description={post.data.description}>

  <article>
    <!-- Back link -->
    <a href="/blog/" class="back-link">← Todos los posts</a>

    <!-- Series banner -->
    {post.data.series && (
      <div class="series-banner">
        <span class="series-label">Serie</span>
        <a href={`/blog/series/${encodeURIComponent(post.data.series)}/`} class="series-name">
          {post.data.series}
        </a>
        <span class="series-part">Parte {seriesIndex + 1} de {seriesPosts.length}</span>
      </div>
    )}

    <!-- Header -->
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.pubDate.toISOString()} class="post-date">
          {formatDate(post.data.pubDate)}
        </time>
        <span class="separator">·</span>
        <span class="read-time">{mins} min de lectura</span>
        {post.data.tags.length > 0 && (
          <>
            <span class="separator">·</span>
            <div class="tag-row">
              {post.data.tags.map((tag: string) => (
                <a href={`/blog/tags/${tag}/`} class="tag">{tag}</a>
              ))}
            </div>
          </>
        )}
      </div>
    </header>

    <!-- Content -->
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </article>

  <!-- Series prev/next -->
  {(prevInSeries || nextInSeries) && (
    <nav class="series-nav">
      <p class="series-nav-label">Más en esta serie</p>
      <div class="series-nav-links">
        {prevInSeries && (
          <a href={`/blog/${prevInSeries.slug}/`} class="series-nav-item series-nav-prev">
            <span class="nav-dir">← Anterior</span>
            <span class="nav-title">{prevInSeries.data.title}</span>
          </a>
        )}
        {nextInSeries && (
          <a href={`/blog/${nextInSeries.slug}/`} class="series-nav-item series-nav-next">
            <span class="nav-dir">Siguiente →</span>
            <span class="nav-title">{nextInSeries.data.title}</span>
          </a>
        )}
      </div>
    </nav>
  )}

  <!-- Related posts -->
  {related.length > 0 && (
    <aside class="related">
      <h2 class="related-title">Posts relacionados</h2>
      <ul class="related-list">
        {related.map((rel: CollectionEntry<'blog'>) => (
          <li class="related-item">
            <a href={`/blog/${rel.slug}/`} class="related-link">
              <span class="related-post-title">{rel.data.title}</span>
              <span class="related-date">{formatDateShort(rel.data.pubDate)}</span>
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )}

</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 150ms ease;
  }
  .back-link:hover { color: var(--color-accent); }

  /* Series banner */
  .series-banner {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background-color: var(--color-surface);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .series-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .series-name {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 150ms ease;
  }
  .series-name:hover { opacity: 0.75; }
  .series-part {
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-left: auto;
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }
  .post-title {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: 0.875rem;
  }
  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .separator { color: var(--color-border); }
  .read-time { font-size: 0.85rem; color: var(--color-muted); }
  .tag-row { display: flex; flex-wrap: wrap; gap: 0.375rem; }
  .tag {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 0.2em 0.55em;
    border-radius: 0.25rem;
    background-color: var(--color-surface-2);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: border-color 150ms ease, color 150ms ease;
  }
  .tag:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* Series nav */
  .series-nav {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .series-nav-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.875rem;
  }
  .series-nav-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .series-nav-item {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.875rem 1.125rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 150ms ease, background-color 150ms ease;
  }
  .series-nav-item:hover { border-color: var(--color-accent); background-color: var(--color-surface); }
  .series-nav-next { text-align: right; }
  .nav-dir {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    text-transform: uppercase;
  }
  .nav-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.35;
    transition: color 150ms ease;
  }
  .series-nav-item:hover .nav-title { color: var(--color-accent); }

  /* Related posts */
  .related {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .related-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }
  .related-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .related-item + .related-item { border-top: 1px solid var(--color-border); }
  .related-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    text-decoration: none;
    transition: background-color 150ms ease;
  }
  .related-link:hover { background-color: var(--color-surface); }
  .related-post-title {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    transition: color 150ms ease;
  }
  .related-link:hover .related-post-title { color: var(--color-accent); }
  .related-date {
    font-size: 0.75rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
