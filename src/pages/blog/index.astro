---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CardList from '../../components/CardList.astro';
import TagPill from '../../components/TagPill.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { readingTime } from '../../utils/reading-time';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const postsByYear = new Map<number, CollectionEntry<'blog'>[]>();
for (const post of posts) {
  const year = post.data.pubDate.getFullYear();
  if (!postsByYear.has(year)) postsByYear.set(year, []);
  postsByYear.get(year)!.push(post);
}
const years = [...postsByYear.keys()].sort((a, b) => b - a);

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', { month: 'short', day: 'numeric' });
}
---

<BaseLayout
  title="Blog — notdefined.dev"
  description="Todos los posts de Adrian Castillo sobre Ruby, JavaScript, backend e IA."
>
  <PageHeader
    label="Escritura"
    title="Blog"
    description="Notas desde las trincheras: Ruby, JavaScript, arquitectura backend y experimentos con IA."
  >
    <div slot="actions" class="header-actions">
      <a href="/blog/tags/" class="action-link">Explorar por tag →</a>
      <span class="action-sep">·</span>
      <a href="/blog/series/" class="action-link">Ver series →</a>
    </div>
  </PageHeader>

  {
    years.map((year) => (
      <section class="year-section">
        <h2 class="year-heading">{year}</h2>
        <CardList>
          {postsByYear.get(year)!.map((post) => (
            <li class="card-list-item fade-in-item">
              <a href={`/blog/${post.slug}/`} class="post-link">
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-desc">{post.data.description}</p>
                <div class="post-footer">
                  <div class="tag-row">
                    {post.data.tags.map((tag: string) => (
                      <TagPill label={tag} />
                    ))}
                  </div>
                  <span class="post-meta">
                    {formatDate(post.data.pubDate)} · {readingTime(post.body)}{' '}
                    min
                  </span>
                </div>
              </a>
            </li>
          ))}
        </CardList>
      </section>
    ))
  }
</BaseLayout>

<style>
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .action-link {
    font-size: 0.85rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 150ms ease;
  }
  .action-link:hover {
    opacity: 0.7;
  }
  .action-sep {
    font-size: 0.85rem;
    color: var(--color-border);
  }

  .year-section {
    margin-bottom: 2rem;
  }

  .year-heading {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.5rem;
    padding-left: 0.25rem;
    opacity: 0.6;
  }

  .post-link {
    display: block;
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: background-color 120ms ease;
  }
  .post-link:hover {
    background-color: var(--color-surface);
  }

  .post-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    margin: 0 0 0.25rem;
    transition: color 120ms ease;
  }
  .post-link:hover .post-title {
    color: var(--color-accent);
  }

  .post-desc {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0 0 0.625rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    min-width: 0;
  }

  .post-meta {
    font-size: 0.72rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0.8;
  }
</style>
