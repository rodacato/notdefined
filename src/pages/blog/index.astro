---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { readingTime } from '../../utils/reading-time';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const postsByYear = new Map<number, CollectionEntry<'blog'>[]>();
for (const post of posts) {
  const year = post.data.pubDate.getFullYear();
  if (!postsByYear.has(year)) postsByYear.set(year, []);
  postsByYear.get(year)!.push(post);
}
const years = [...postsByYear.keys()].sort((a, b) => b - a);

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', { month: 'short', day: 'numeric' });
}
---

<BaseLayout title="Blog — notdefined.dev" description="Todos los posts de Adrian Castillo sobre Ruby, JavaScript, backend e IA.">

  <header class="mb-10">
    <p class="label mb-2">Escritura</p>
    <h1 class="page-title">Blog</h1>
    <p class="page-desc">Notas desde las trincheras — Ruby, JavaScript, arquitectura backend, y algún que otro experimento con IA.</p>
    <div class="header-actions">
      <a href="/blog/tags/" class="action-link">Explorar por tag →</a>
      <span class="action-sep">·</span>
      <a href="/blog/series/" class="action-link">Ver series →</a>
    </div>
  </header>

  {years.map((year) => (
    <section class="year-section">
      <h2 class="year-heading">{year}</h2>
      <ul class="post-list">
        {postsByYear.get(year)!.map((post: CollectionEntry<'blog'>, i: number) => (
          <li class={i > 0 ? 'post-item bordered' : 'post-item'}>
            <a href={`/blog/${post.slug}/`} class="post-link">
              <h3 class="post-title">{post.data.title}</h3>
              <p class="post-desc">{post.data.description}</p>
              <div class="post-footer">
                <div class="tag-row">
                  {post.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <span class="post-meta">{formatDate(post.data.pubDate)} · {readingTime(post.body)} min</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}

</BaseLayout>

<style>
  .label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .page-title {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  .page-desc {
    color: var(--color-muted);
    font-size: 0.95rem;
    max-width: 36rem;
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
  .action-link {
    font-size: 0.85rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 150ms ease;
  }
  .action-link:hover { opacity: 0.7; }
  .action-sep { font-size: 0.85rem; color: var(--color-border); }

  .year-section { margin-bottom: 2rem; }
  .year-heading {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.5rem;
    padding-left: 0.25rem;
    opacity: 0.6;
  }

  .post-list {
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    overflow: hidden;
  }
  .post-item.bordered { border-top: 1px solid var(--color-border); }

  .post-link {
    display: block;
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: background-color 120ms ease;
  }
  .post-link:hover { background-color: var(--color-surface); }

  .post-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    margin: 0 0 0.25rem;
    transition: color 120ms ease;
  }
  .post-link:hover .post-title { color: var(--color-accent); }

  .post-desc {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0 0 0.625rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .tag-row { display: flex; flex-wrap: wrap; gap: 0.25rem; min-width: 0; }
  .tag {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    padding: 0.15em 0.5em;
    border-radius: 0.2rem;
    background-color: var(--color-surface-2);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    white-space: nowrap;
  }
  .post-meta {
    font-size: 0.72rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0.8;
  }
</style>
