---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import CardList from '../../../components/CardList.astro';
import TagPill from '../../../components/TagPill.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  const tagSet = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) tagSet.add(tag);
  }

  return [...tagSet].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props as {
  tag: string;
  posts: CollectionEntry<'blog'>[];
};

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={`#${tag} — notdefined.dev`}
  description={`Posts etiquetados con "${tag}" en notdefined.dev.`}
>
  <PageHeader
    backHref="/blog/tags/"
    backLabel="← Todos los tags"
    label="Tag"
    title={`#${tag}`}
    description={`${posts.length} post${posts.length !== 1 ? 's' : ''}`}
  />

  <CardList>
    {
      posts.map((post) => (
        <li class="card-list-item">
          <a href={`/blog/${post.slug}/`} class="post-link">
            <div class="post-meta">
              <span class="post-title">{post.data.title}</span>
              <p class="post-desc">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="tag-row">
                  {post.data.tags.map((itemTag: string) => (
                    <TagPill
                      label={itemTag}
                      href={`/blog/tags/${itemTag}/`}
                      active={itemTag === tag}
                    />
                  ))}
                </div>
              )}
            </div>
            <span class="post-date">{formatDate(post.data.pubDate)}</span>
          </a>
        </li>
      ))
    }
  </CardList>
</BaseLayout>

<style>
  .post-link {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    transition: background-color 150ms ease;
    text-decoration: none;
  }
  .post-link:hover {
    background-color: var(--color-surface);
  }

  .post-meta {
    flex: 1;
    min-width: 0;
  }

  .post-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    display: block;
    margin-bottom: 0.25rem;
  }
  .post-link:hover .post-title {
    color: var(--color-accent);
  }

  .post-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.625rem;
  }

  .post-date {
    font-size: 0.78rem;
    color: var(--color-muted);
    white-space: nowrap;
    padding-top: 0.15rem;
    flex-shrink: 0;
  }
</style>
