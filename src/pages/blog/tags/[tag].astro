---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  const tagSet = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) tagSet.add(tag);
  }

  return [...tagSet].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props as { tag: string; posts: CollectionEntry<'blog'>[] };

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<BaseLayout
  title={`#${tag} — notdefined.dev`}
  description={`Posts etiquetados con "${tag}" en notdefined.dev.`}
>

  <header class="mb-10">
    <a href="/blog/tags/" class="back-link">← Todos los tags</a>
    <p class="label mb-2">Tag</p>
    <h1 class="page-title">#{tag}</h1>
    <p class="page-desc">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
  </header>

  <ul class="post-list">
    {posts.map((post: CollectionEntry<'blog'>, i: number) => (
      <li class={i > 0 ? 'post-item bordered' : 'post-item'}>
        <a href={`/blog/${post.slug}/`} class="post-link">
          <div class="post-meta">
            <span class="post-title">{post.data.title}</span>
            <p class="post-desc">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="tag-row">
                {post.data.tags.map((t: string) => (
                  <a
                    href={`/blog/tags/${t}/`}
                    class={`tag${t === tag ? ' tag-active' : ''}`}
                    onclick="event.stopPropagation()"
                  >{t}</a>
                ))}
              </div>
            )}
          </div>
          <span class="post-date">{formatDate(post.data.pubDate)}</span>
        </a>
      </li>
    ))}
  </ul>

</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 150ms ease;
  }
  .back-link:hover { color: var(--color-accent); }

  .label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .page-title {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  .page-desc {
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .post-list {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .post-item.bordered { border-top: 1px solid var(--color-border); }
  .post-link {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    transition: background-color 150ms ease;
    text-decoration: none;
  }
  .post-link:hover { background-color: var(--color-surface); }
  .post-meta { flex: 1; min-width: 0; }
  .post-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    display: block;
    margin-bottom: 0.25rem;
  }
  .post-link:hover .post-title { color: var(--color-accent); }
  .post-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0;
  }
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.625rem;
  }
  .tag {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 0.2em 0.55em;
    border-radius: 0.25rem;
    background-color: var(--color-surface-2);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    text-decoration: none;
  }
  .tag-active {
    background-color: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }
  .post-date {
    font-size: 0.78rem;
    color: var(--color-muted);
    white-space: nowrap;
    padding-top: 0.15rem;
    flex-shrink: 0;
  }
</style>
