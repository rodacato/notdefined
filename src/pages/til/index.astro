---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CardList from '../../components/CardList.astro';
import TagPill from '../../components/TagPill.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const entries = (await getCollection('til')).sort(
  (a: CollectionEntry<'til'>, b: CollectionEntry<'til'>) =>
    b.data.date.valueOf() - a.data.date.valueOf(),
);

const byMonth = new Map<string, CollectionEntry<'til'>[]>();
for (const entry of entries) {
  const key = entry.data.date.toLocaleDateString('es-MX', {
    year: 'numeric',
    month: 'long',
  });
  if (!byMonth.has(key)) byMonth.set(key, []);
  byMonth.get(key)!.push(entry);
}
const months = [...byMonth.keys()];

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', { month: 'short', day: 'numeric' });
}
---

<BaseLayout
  title="TIL — notdefined.dev"
  description="Today I Learned: aprendizajes cortos y concretos de Adrian Castillo."
>
  <PageHeader
    label="Base de conocimiento"
    title="TIL"
    description="Cosas que aprendí hoy. Sin estructura y sin pretensiones; lo suficiente para no olvidarlas."
  />

  {
    months.map((month) => (
      <section class="month-section">
        <h2 class="month-heading">{month}</h2>
        <CardList>
          {byMonth.get(month)!.map((entry) => (
            <li class="card-list-item">
              <a href={`/til/${entry.slug}/`} class="til-link">
                <span class="til-title">{entry.data.title}</span>
                <div class="til-footer">
                  <div class="tag-row">
                    {entry.data.tags.map((tag: string) => (
                      <TagPill label={tag} />
                    ))}
                  </div>
                  <span class="til-date">{formatDate(entry.data.date)}</span>
                </div>
              </a>
            </li>
          ))}
        </CardList>
      </section>
    ))
  }
</BaseLayout>

<style>
  .month-section {
    margin-bottom: 2rem;
  }

  .month-heading {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.5rem;
    padding-left: 0.25rem;
    opacity: 0.6;
  }

  .til-link {
    display: block;
    padding: 0.875rem 1.25rem;
    text-decoration: none;
    transition: background-color 120ms ease;
  }
  .til-link:hover {
    background-color: var(--color-surface);
  }

  .til-title {
    display: block;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    margin-bottom: 0.5rem;
    transition: color 120ms ease;
  }
  .til-link:hover .til-title {
    color: var(--color-accent);
  }

  .til-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    min-width: 0;
  }

  .til-date {
    font-size: 0.72rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0.8;
  }
</style>
