---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const groups = [
  {
    title: 'Lenguajes & frameworks',
    items: [
      { name: 'Ruby / Rails', note: 'mi base — APIs, DDD, Hotwire' },
      { name: 'TypeScript / Node', note: 'Hono y Express para servicios' },
      { name: 'React', note: 'front en Vite, sin frameworks de más' },
      { name: 'React Native / Expo', note: 'mobile-first, Android primero' },
      { name: 'Astro', note: 'este sitio, estático y sin JS de adorno' },
    ],
  },
  {
    title: 'Datos',
    items: [
      { name: 'PostgreSQL', note: 'el default para casi todo' },
      { name: 'Redis', note: 'cache y colas cuando hace falta' },
      { name: 'Firestore', note: 'offline-first en mi-feria' },
    ],
  },
  {
    title: 'Infra & deploy',
    items: [
      { name: 'Hetzner', note: 'VPS en Helsinki, sin sobre-provisionar' },
      { name: 'Kamal', note: 'deploys sin la complejidad de Kubernetes' },
      { name: 'Docker', note: 'multi-stage builds, imágenes chicas' },
      { name: 'Cloudflare Tunnel', note: 'ingress sin abrir puertos' },
      { name: 'Tailscale', note: 'acceso admin por mesh privada' },
      { name: 'GitHub Actions', note: 'CI/CD con deploys por branch' },
    ],
  },
  {
    title: 'Calidad & observabilidad',
    items: [
      { name: 'SonarQube', note: 'self-hosted, quality gates por workspace' },
      { name: 'Tests + e2e', note: 'CI que falla feo si algo se rompe' },
      { name: 'Sentry', note: 'errores en producción sin adivinar' },
    ],
  },
];
---

<BaseLayout
  title="Uses — notdefined.dev"
  description="El stack, la infra y las herramientas con las que construyo."
>
  <PageHeader
    label="Setup"
    title="Uses"
    description="Con qué construyo. No es aspiracional — es lo que corre en mis proyectos hoy."
  />

  {
    groups.map((group) => (
      <section class="uses-group">
        <h2 class="uses-title">{group.title}</h2>
        <ul class="uses-list">
          {group.items.map((item) => (
            <li class="uses-item">
              <span class="uses-name">{item.name}</span>
              <span class="uses-note">{item.note}</span>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</BaseLayout>

<style>
  .uses-group {
    margin-bottom: 2.5rem;
  }

  .uses-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 1rem;
  }

  .uses-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .uses-item {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
  }

  .uses-item + .uses-item {
    border-top: 1px solid var(--color-border);
  }

  .uses-name {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    flex-shrink: 0;
    min-width: 11rem;
  }

  .uses-note {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  @media (max-width: 30rem) {
    .uses-item {
      flex-direction: column;
      gap: 0.2rem;
    }
    .uses-name {
      min-width: 0;
    }
  }
</style>
