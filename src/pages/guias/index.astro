---
import RealmLayout from '../../layouts/RealmLayout.astro';
import TagPill from '../../components/TagPill.astro';
import { guias } from '../../data/guias';

const ordered = [...guias].sort((a, b) => a.tomo - b.tomo);

const ROMAN = ['', 'I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X'];
---

<RealmLayout
  title="Guías — notdefined.dev"
  description="Nivel desbloqueado. Referencias interactivas para aprender y recordar: cada guía es su propia página, con su propio diseño y paleta."
>
  <section class="realm" aria-label="Guías">
    <header class="realm-head">
      <p class="realm-tag">
        REFERENCIA <span class="sep">//</span> NIVEL DESBLOQUEADO<span
          class="cur">_</span
        >
      </p>
      <h1 class="realm-title realm-glitch" data-text="Guías">Guías</h1>
      <p class="realm-lede">
        La colección. Referencias interactivas que se consultan, no que se leen
        de corrido — cada tomo es su propia página, con su paleta y su
        tipografía. Entraste por la puerta de siempre; también hay una secreta.
      </p>
    </header>

    <ol class="shelf">
      {
        ordered.map((guia) => (
          <li
            class:list={['spine', `texture-${guia.theme.texture}`]}
            style={`--g-canvas:${guia.theme.canvas};--g-ink:${guia.theme.ink};--g-soft:${guia.theme.inkSoft};--g-accent:${guia.theme.accent};--g-border:${guia.theme.border};--g-display:'${guia.theme.displayFamily}';`}
          >
            <a href={`/guias/${guia.slug}/`} class="spine-link">
              <div class="spine-rail">
                <span class="spine-tomo">{ROMAN[guia.tomo]}</span>
                <span class="spine-tomo-label">Tomo</span>
              </div>
              <div class="spine-body">
                <h2 class="spine-title">{guia.title}</h2>
                <p class="spine-blurb">{guia.blurb}</p>
                <div class="spine-foot">
                  <div class="spine-tags">
                    {guia.tags.map((t) => (
                      <TagPill label={t} />
                    ))}
                  </div>
                  <span class="spine-cta">Ábrela →</span>
                </div>
              </div>
            </a>
          </li>
        ))
      }
    </ol>
  </section>
</RealmLayout>

<style>
  /* Fuentes display de cada guía, self-hosteadas desde su carpeta (peso 700).
     Renombradas con prefijo "Guia " para no chocar si el sitio adopta alguna. */
  @font-face {
    font-family: 'Guia Bitter';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/design-patterns-1001/fonts/bitter-700.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Chakra Petch';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/architectures-1001/fonts/chakra-petch-700.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Space Grotesk';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/algorithms-1001/fonts/space-grotesk-700.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Fraunces';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/apis-1001/fonts/Fraunces-Bold.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Guia Playfair';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/auth-1001/fonts/playfair-display-700.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Lora';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/databases-1001/fonts/lora-700.woff2') format('woff2');
  }

  .realm-head {
    margin-bottom: 2rem;
  }
  .realm-tag {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    color: #7fd8a6;
    margin: 0 0 0.7rem;
    text-transform: uppercase;
  }
  .realm-tag .sep {
    color: #8fa39d;
    opacity: 0.7;
  }
  .realm-tag .cur {
    animation: realm-blink 1.1s steps(1) infinite;
  }
  .realm-title {
    font-size: clamp(2.2rem, 6vw, 3.4rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0;
    color: #eef3f2;
    width: fit-content;
  }
  .realm-lede {
    margin: 0.9rem 0 0;
    max-width: 62ch;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #8fa39d;
  }

  /* ---- El estante: rows lomo-de-libro ---- */
  .shelf {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Cada spine adopta la paleta oscura + textura + fuente display de su guía. */
  .spine {
    border: 1px solid var(--g-border);
    border-radius: 0.9rem;
    background-color: var(--g-canvas);
    overflow: hidden;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }
  .spine.texture-grid {
    background-image:
      linear-gradient(
        color-mix(in srgb, var(--g-accent) 8%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--g-accent) 8%, transparent) 1px,
        transparent 1px
      );
    background-size: 22px 22px;
  }
  .spine.texture-grain {
    background-image: repeating-linear-gradient(
      90deg,
      color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
      transparent 1px 46px
    );
  }
  /* par-avion postal (apis) */
  .spine.texture-stripes {
    background-image: repeating-linear-gradient(
      45deg,
      color-mix(in srgb, var(--g-accent) 7%, transparent) 0 2px,
      transparent 2px 26px
    );
  }
  /* guilloché de documento de seguridad (auth) */
  .spine.texture-arcs {
    background-image: repeating-radial-gradient(
      circle at 0 130%,
      color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
      transparent 1px 22px
    );
  }
  /* renglones de ficha de catálogo (databases) */
  .spine.texture-rules {
    background-image: repeating-linear-gradient(
      0deg,
      color-mix(in srgb, var(--g-accent) 8%, transparent) 0 1px,
      transparent 1px 26px
    );
  }
  .spine:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--g-accent) 55%, var(--g-border));
    box-shadow: 0 16px 40px -20px rgba(0, 0, 0, 0.7);
  }

  .spine-link {
    display: flex;
    gap: clamp(0.9rem, 3vw, 1.6rem);
    align-items: stretch;
    padding: clamp(1.1rem, 3vw, 1.5rem) clamp(1.2rem, 3.5vw, 1.7rem);
    text-decoration: none;
    color: var(--g-ink);
  }

  .spine-rail {
    flex: none;
    width: 3.2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.15rem;
    border-right: 1px solid color-mix(in srgb, var(--g-border) 70%, transparent);
    padding-right: clamp(0.6rem, 2vw, 1rem);
  }
  .spine-tomo {
    /* Serif fija para el numeral: sin serifas, II/III se ven como barras. */
    font-family: Georgia, 'Iowan Old Style', 'Times New Roman', serif;
    font-weight: 700;
    font-size: 1.9rem;
    line-height: 1;
    color: var(--g-accent);
  }
  .spine-tomo-label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--g-soft);
  }

  .spine-body {
    flex: 1;
    min-width: 0;
  }
  .spine-title {
    font-family: var(--g-display), Georgia, serif;
    font-weight: 700;
    font-size: clamp(1.3rem, 3.4vw, 1.85rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--g-ink);
  }
  .spine-blurb {
    margin: 0.55rem 0 0;
    font-size: 0.86rem;
    line-height: 1.55;
    color: var(--g-soft);
  }
  .spine-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 0.95rem;
  }
  .spine-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .spine-cta {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--g-accent);
    white-space: nowrap;
  }

  @media (max-width: 560px) {
    .spine-link {
      flex-direction: column;
    }
    .spine-rail {
      flex-direction: row;
      width: auto;
      justify-content: flex-start;
      gap: 0.5rem;
      border-right: 0;
      border-bottom: 1px solid
        color-mix(in srgb, var(--g-border) 70%, transparent);
      padding: 0 0 0.6rem;
    }
    .spine-tomo {
      font-size: 1.4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .realm-tag .cur {
      animation: none;
    }
    .spine {
      transition: none;
    }
    .spine:hover {
      transform: none;
    }
  }

  /* El tag-pill del sitio hereda tokens claros y una animación de aterrizaje
     que dispara un script de BaseLayout (que aquí no existe): dentro del spine
     lo re-tiño a la paleta de la guía y lo dejo visible sin animación. */
  .spine :global(.tag-pill) {
    background: color-mix(in srgb, var(--g-accent) 14%, transparent);
    border-color: color-mix(in srgb, var(--g-accent) 32%, transparent);
    color: var(--g-ink);
    animation: none;
    opacity: 1;
    transform: none;
  }
</style>
