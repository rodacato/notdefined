---
import RealmLayout from '../../layouts/RealmLayout.astro';
import { guias, type Guia, type GuiaNivel } from '../../data/guias';

const ROMAN = ['', 'I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X'];

// Almanaque 1001: bookshelf de lomos, ordenado por tomo.
const almanaque = guias
  .filter((g) => g.collection === 'almanaque-1001')
  .sort((a, b) => (a.tomo ?? 99) - (b.tomo ?? 99));

// Polyglot: agrupado por lenguaje, niveles como filas. Escala C1 → C2.
const langOf = (title: string) =>
  title.replace(/ (a fondo|dominado|con soltura)$/, '');

const NIVEL_HUB: GuiaNivel[] = ['C1', 'C2'];
const NIVEL_LABEL: Record<GuiaNivel, string> = {
  C1: 'dominado',
  C2: 'a fondo',
};
// La definición de cada nivel (del ADR 0006) — una línea, no el blurb largo.
const NIVEL_DESC: Record<GuiaNivel, string> = {
  C1: 'uso experto del lenguaje',
  C2: 'el motor por dentro',
};

const polyByLang = new Map<string, Guia[]>();
for (const g of guias.filter((x) => x.collection === 'polyglot')) {
  const k = langOf(g.title);
  (polyByLang.get(k) ?? polyByLang.set(k, []).get(k)!).push(g);
}
const langGroups = [...polyByLang.entries()].map(([lang, gs]) => ({
  lang,
  theme: gs[0].theme,
  levels: gs.sort(
    (a, b) => NIVEL_HUB.indexOf(a.nivel!) - NIVEL_HUB.indexOf(b.nivel!),
  ),
}));
---

<RealmLayout
  title="Guías — notdefined.dev"
  description="Nivel desbloqueado. Referencias interactivas para aprender y recordar: cada guía es su propia página, con su propio diseño y paleta."
>
  <section class="realm" aria-label="Guías">
    <header class="realm-head">
      <p class="realm-tag">
        REFERENCIA <span class="sep">//</span> NIVEL DESBLOQUEADO<span
          class="cur">_</span
        >
      </p>
      <h1 class="realm-title realm-glitch" data-text="Guías">Guías</h1>
      <p class="realm-lede">
        La colección. Referencias interactivas que se consultan, no que se leen
        de corrido — cada guía es su propia página, con su paleta y su
        tipografía. Entraste por la puerta de siempre; también hay una secreta.
      </p>
    </header>

    <!-- ALMANAQUE — bookshelf de lomos -->
    <section class="shelf-section" aria-label="Almanaque técnico 1001">
      <header class="shelf-head">
        <p class="shelf-name">
          COLECCIÓN 01 <span class="sep">//</span> ALMANAQUE TÉCNICO · 1001
          <span class="shelf-count">{almanaque.length} tomos</span>
        </p>
        <p class="shelf-hook">Pasa el mouse por un lomo para abrirlo.</p>
      </header>
      <ol class="bookshelf">
        {
          almanaque.map((g) => (
            <li
              class:list={['bookspine', `texture-${g.theme.texture}`]}
              style={`--g-canvas:${g.theme.canvas};--g-ink:${g.theme.ink};--g-soft:${g.theme.inkSoft};--g-accent:${g.theme.accent};--g-border:${g.theme.border};--g-display:'${g.theme.displayFamily}';`}
              tabindex="0"
            >
              <div class="bs-inner">
                <div class="bs-closed">
                  <span class="bs-badge">{ROMAN[g.tomo!]}</span>
                  <span class="bs-vtitle">
                    {g.title.replace(/\s*1001$/, '')}
                  </span>
                  <span class="bs-dot" />
                </div>
                <div class="bs-open">
                  <span class="bs-open-badge">{ROMAN[g.tomo!]} · Tomo</span>
                  <h2 class="bs-title">{g.title.replace(/\s*1001$/, '')}</h2>
                  <p class="bs-blurb">{g.blurb}</p>
                  <div class="bs-tags">
                    {g.tags.map((t) => (
                      <span class="bs-tag">{t}</span>
                    ))}
                  </div>
                  <a href={`/guias/${g.slug}/`} class="bs-cta">
                    Ábrela →
                  </a>
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </section>

    <!-- POLYGLOT — agrupado por lenguaje, niveles C1 → C2 -->
    <section class="shelf-section" aria-label="Polyglot">
      <header class="shelf-head">
        <p class="shelf-name">
          COLECCIÓN 02 <span class="sep">//</span> POLYGLOT
          <span class="shelf-count">
            {langGroups.length}
            {langGroups.length === 1 ? ' lenguaje' : ' lenguajes'}
          </span>
        </p>
        <p class="shelf-hook">
          Temas avanzados de cada lenguaje, en escala de idiomas: C1 y C2.
        </p>
      </header>
      <div class="lang-grid">
        {
          langGroups.map((grp) => (
            <article
              class:list={['lang-card', `texture-${grp.theme.texture}`]}
              style={`--g-canvas:${grp.theme.canvas};--g-ink:${grp.theme.ink};--g-soft:${grp.theme.inkSoft};--g-accent:${grp.theme.accent};--g-border:${grp.theme.border};--g-display:'${grp.theme.displayFamily}';`}
            >
              <div class="lang-head">
                <h2 class="lang-name">{grp.lang}</h2>
                <span class="lang-count">{grp.levels.length} de 2 niveles</span>
              </div>
              <ul class="lvl-list">
                {NIVEL_HUB.map((lvl) => {
                  const g = grp.levels.find((x) => x.nivel === lvl);
                  return g ? (
                    <li class="lvl-row is-live">
                      <span class="lvl-badge">{lvl}</span>
                      <div class="lvl-text">
                        <span class="lvl-name">{NIVEL_LABEL[lvl]}</span>
                        <span class="lvl-desc">{NIVEL_DESC[lvl]}</span>
                      </div>
                      <a href={`/guias/${g.slug}/`} class="lvl-cta">
                        Ábrela →
                      </a>
                    </li>
                  ) : (
                    <li class="lvl-row is-soon">
                      <span class="lvl-badge">{lvl}</span>
                      <div class="lvl-text">
                        <span class="lvl-name">{NIVEL_LABEL[lvl]}</span>
                        <span class="lvl-desc">pronto</span>
                      </div>
                    </li>
                  );
                })}
              </ul>
            </article>
          ))
        }
      </div>
    </section>
  </section>
</RealmLayout>

<style>
  @font-face {
    font-family: 'Guia Spectral';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/polyglot-ruby-c2/fonts/Spectral-Bold.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Bitter';
    font-weight: 700;
    font-display: swap;
    src: url('/guias/design-patterns-1001/fonts/bitter-700.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Chakra Petch';
    font-weight: 700;
    font-display: swap;
    src: url('/guias/architectures-1001/fonts/chakra-petch-700.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Space Grotesk';
    font-weight: 700;
    font-display: swap;
    src: url('/guias/algorithms-1001/fonts/space-grotesk-700.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Fraunces';
    font-weight: 700;
    font-display: swap;
    src: url('/guias/apis-1001/fonts/Fraunces-Bold.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Guia Playfair';
    font-weight: 700;
    font-display: swap;
    src: url('/guias/auth-1001/fonts/playfair-display-700.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Lora';
    font-weight: 700;
    font-display: swap;
    src: url('/guias/databases-1001/fonts/lora-700.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Guia Barlow Condensed';
    font-weight: 700;
    font-display: swap;
    src: url('/guias/messaging-1001/fonts/barlow-condensed-700.woff2')
      format('woff2');
  }

  .realm-head {
    margin-bottom: 2rem;
  }
  .realm-tag {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    color: #7fd8a6;
    margin: 0 0 0.7rem;
    text-transform: uppercase;
  }
  .realm-tag .sep {
    color: #8fa39d;
    opacity: 0.7;
  }
  .realm-tag .cur {
    animation: realm-blink 1.1s steps(1) infinite;
  }
  .realm-title {
    font-size: clamp(2.2rem, 6vw, 3.4rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0;
    color: #eef3f2;
    width: fit-content;
  }
  .realm-lede {
    margin: 0.9rem 0 0;
    max-width: 62ch;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #8fa39d;
  }

  .shelf-section {
    margin-top: 2.6rem;
  }
  .shelf-head {
    margin-bottom: 1rem;
  }
  .shelf-name {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: #eef3f2;
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .shelf-name .sep {
    color: #8fa39d;
    opacity: 0.7;
  }
  .shelf-count {
    margin-left: auto;
    font-size: 0.68rem;
    color: #7fd8a6;
    opacity: 0.8;
  }
  .shelf-hook {
    margin: 0.35rem 0 0;
    font-size: 0.85rem;
    color: #8fa39d;
  }

  /* ---- Texturas por guía (mismas fórmulas que las portadas) ----
     Polyglot (lang-card): siempre visible, la tarjeta es ancha.
     Almanaque (bookspine): solo al expandir, vía ::before — colapsado y
     angosto choca con la retícula de la página. ------------------------- */
  .bookspine::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 220ms ease 90ms;
  }
  .bookspine:hover::before,
  .bookspine:focus::before,
  .bookspine:focus-within::before {
    opacity: 1;
  }

  .bookspine.texture-grid::before,
  .lang-card.texture-grid {
    background-image:
      linear-gradient(
        color-mix(in srgb, var(--g-accent) 8%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--g-accent) 8%, transparent) 1px,
        transparent 1px
      );
    background-size: 22px 22px;
  }
  .bookspine.texture-grain::before,
  .lang-card.texture-grain {
    background-image: repeating-linear-gradient(
      90deg,
      color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
      transparent 1px 46px
    );
  }
  .bookspine.texture-stripes::before,
  .lang-card.texture-stripes {
    background-image: repeating-linear-gradient(
      45deg,
      color-mix(in srgb, var(--g-accent) 7%, transparent) 0 2px,
      transparent 2px 26px
    );
  }
  .bookspine.texture-arcs::before,
  .lang-card.texture-arcs {
    background-image: repeating-radial-gradient(
      circle at 0 130%,
      color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
      transparent 1px 22px
    );
  }
  .bookspine.texture-rules::before,
  .lang-card.texture-rules {
    background-image: repeating-linear-gradient(
      0deg,
      color-mix(in srgb, var(--g-accent) 8%, transparent) 0 1px,
      transparent 1px 26px
    );
  }
  .bookspine.texture-facets::before,
  .lang-card.texture-facets {
    background-image:
      repeating-linear-gradient(
        60deg,
        color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
        transparent 1px 34px
      ),
      repeating-linear-gradient(
        -60deg,
        color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
        transparent 1px 34px
      );
  }
  .bookspine.texture-lattice::before,
  .lang-card.texture-lattice {
    background-image:
      repeating-linear-gradient(
        30deg,
        color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
        transparent 1px 38px
      ),
      repeating-linear-gradient(
        -30deg,
        color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
        transparent 1px 38px
      );
  }
  .bookspine.texture-twill::before,
  .lang-card.texture-twill {
    background-image: repeating-linear-gradient(
      135deg,
      color-mix(in srgb, var(--g-accent) 8%, transparent) 0 1px,
      transparent 1px 30px
    );
  }
  .bookspine.texture-morse::before,
  .lang-card.texture-morse {
    background-image:
      repeating-linear-gradient(
        0deg,
        var(--g-canvas) 0 27px,
        transparent 27px 28px
      ),
      repeating-linear-gradient(
        90deg,
        color-mix(in srgb, var(--g-accent) 12%, transparent) 0 10px,
        transparent 10px 18px,
        color-mix(in srgb, var(--g-accent) 12%, transparent) 18px 21px,
        transparent 21px 38px
      );
  }

  /* ---- Bookshelf (almanaque) ---- */
  .bookshelf {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 8px;
    height: 320px;
  }
  .bookspine {
    flex: 1 1 62px;
    min-width: 56px;
    border: 1px solid var(--g-border);
    border-radius: 0.7rem;
    background-color: var(--g-canvas);
    overflow: hidden;
    position: relative;
    cursor: default;
    transition:
      flex-grow 280ms cubic-bezier(0.22, 1, 0.36, 1),
      background-color 220ms ease,
      border-color 220ms ease;
  }
  .bookspine:hover,
  .bookspine:focus,
  .bookspine:focus-within {
    flex-grow: 8;
    background-color: color-mix(in srgb, var(--g-accent) 8%, var(--g-canvas));
    border-color: color-mix(in srgb, var(--g-accent) 40%, var(--g-border));
  }
  .bookspine:focus-visible {
    outline: 2px solid var(--g-accent);
    outline-offset: 2px;
  }
  .bs-inner {
    display: block;
    position: relative;
    z-index: 1;
    height: 100%;
    color: var(--g-ink);
  }
  .bs-closed {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.75rem 0;
    gap: 0.6rem;
    transition: opacity 160ms ease;
  }
  .bookspine:hover .bs-closed,
  .bookspine:focus .bs-closed,
  .bookspine:focus-within .bs-closed {
    opacity: 0;
  }
  .bs-badge {
    font-family: Georgia, serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--g-accent);
  }
  .bs-vtitle {
    writing-mode: vertical-rl;
    font-family: var(--g-display), Georgia, serif;
    font-weight: 700;
    font-size: 0.94rem;
    letter-spacing: 0.01em;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .bs-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--g-accent);
  }
  .bs-open {
    position: absolute;
    inset: 0;
    padding: 1.1rem 1.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 320px;
    opacity: 0;
    transition: opacity 240ms ease 140ms;
  }
  .bookspine:hover .bs-open,
  .bookspine:focus .bs-open,
  .bookspine:focus-within .bs-open {
    opacity: 1;
  }
  .bs-open-badge {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--g-accent);
  }
  .bs-title {
    font-family: var(--g-display), Georgia, serif;
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.1;
    margin: 0;
  }
  .bs-blurb {
    font-size: 0.8rem;
    line-height: 1.45;
    color: var(--g-soft);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .bs-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.2rem;
  }
  .bs-tag {
    font-size: 0.66rem;
    padding: 0.12rem 0.5rem;
    border-radius: 0.35rem;
    background: color-mix(in srgb, var(--g-accent) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--g-accent) 32%, transparent);
    color: var(--g-ink);
    white-space: nowrap;
  }
  .bs-cta {
    margin-top: auto;
    align-self: flex-start;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--g-accent);
    text-decoration: none;
    cursor: pointer;
  }
  .bs-cta:hover {
    text-decoration: underline;
  }

  /* ---- Polyglot: tarjetas por lenguaje con filas de nivel ---- */
  .lang-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr));
    gap: 1rem;
  }
  .lang-card {
    border: 1px solid var(--g-border);
    border-radius: 0.9rem;
    background-color: var(--g-canvas);
    padding: 1.3rem 1.4rem;
    color: var(--g-ink);
  }
  .lang-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 1rem;
  }
  .lang-name {
    font-family: var(--g-display), Georgia, serif;
    font-weight: 700;
    font-size: 1.7rem;
    line-height: 1;
    margin: 0;
    color: var(--g-ink);
  }
  .lang-count {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--g-soft);
  }
  .lvl-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .lvl-row {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.55rem 0.7rem;
    border-radius: 0.6rem;
    border: 1px solid var(--g-border);
  }
  .lvl-row.is-live {
    background: color-mix(in srgb, var(--g-accent) 12%, transparent);
    border-color: color-mix(in srgb, var(--g-accent) 34%, transparent);
  }
  .lvl-row.is-soon {
    opacity: 0.42;
  }
  .lvl-badge {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--g-accent);
    flex: none;
    width: 2ch;
    text-align: center;
  }
  .lvl-row.is-soon .lvl-badge {
    color: var(--g-soft);
  }
  .lvl-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .lvl-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--g-ink);
  }
  .lvl-row.is-soon .lvl-name {
    color: var(--g-soft);
  }
  .lvl-desc {
    font-size: 0.75rem;
    color: var(--g-soft);
  }
  .lvl-cta {
    margin-left: auto;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--g-accent);
    text-decoration: none;
    white-space: nowrap;
  }
  .lvl-cta:hover {
    text-decoration: underline;
  }

  @media (max-width: 720px) {
    /* Sin hover en táctil: los lomos se muestran como tarjetas ya abiertas. */
    .bookshelf {
      flex-direction: column;
      height: auto;
    }
    .bookspine {
      flex: none;
    }
    .bs-closed {
      display: none;
    }
    .bs-open {
      position: static;
      opacity: 1;
      min-width: 0;
      padding: 1.1rem 1.2rem;
    }
    .lang-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .bookspine,
    .bs-closed,
    .bs-open {
      transition: none;
    }
  }
</style>
