---
import RealmLayout from '../../layouts/RealmLayout.astro';
import TagPill from '../../components/TagPill.astro';
import { guias, collections } from '../../data/guias';

const ROMAN = ['', 'I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X'];

// Un estante por colección, en el orden del registro; vacíos no se pintan.
// Dentro del estante: los tomos por número; Polyglot queda en orden de
// publicación (sin tomo, el sort es estable).
const shelves = collections
  .map((col) => ({
    col,
    items: guias
      .filter((g) => g.collection === col.id)
      .sort((a, b) => (a.tomo ?? 99) - (b.tomo ?? 99)),
  }))
  .filter((s) => s.items.length > 0);

// Dentro de su estante, el sufijo "1001" del lomo es redundante: lo carga
// el encabezado de la colección. El título completo vive dentro de la guía.
function spineTitle(title: string, collection: string) {
  return collection === 'almanaque-1001'
    ? title.replace(/\s*1001$/, '')
    : title;
}
---

<RealmLayout
  title="Guías — notdefined.dev"
  description="Nivel desbloqueado. Referencias interactivas para aprender y recordar: cada guía es su propia página, con su propio diseño y paleta."
>
  <section class="realm" aria-label="Guías">
    <header class="realm-head">
      <p class="realm-tag">
        REFERENCIA <span class="sep">//</span> NIVEL DESBLOQUEADO<span
          class="cur">_</span
        >
      </p>
      <h1 class="realm-title realm-glitch" data-text="Guías">Guías</h1>
      <p class="realm-lede">
        La colección. Referencias interactivas que se consultan, no que se leen
        de corrido — cada guía es su propia página, con su paleta y su
        tipografía. Entraste por la puerta de siempre; también hay una secreta.
      </p>
    </header>

    {
      shelves.map((shelf, i) => (
        <details class="shelf-section" open data-col={shelf.col.id}>
          <summary class="shelf-summary">
            <span class="shelf-name">
              COLECCIÓN {String(i + 1).padStart(2, '0')}{' '}
              <span class="sep">//</span> {shelf.col.name.toUpperCase()}
            </span>
            <span class="shelf-count">
              {shelf.items.length}{' '}
              {shelf.items.length === 1
                ? shelf.col.itemLabel.replace(/s$/, '')
                : shelf.col.itemLabel}
            </span>
            <svg class="shelf-chevron" viewBox="0 0 12 12" aria-hidden="true">
              <path
                d="M4.5 2.5 L8 6 L4.5 9.5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            {/* Dentro del summary a propósito: colapsada, la colección sigue
                diciendo qué guarda. */}
            <span class="shelf-hook">{shelf.col.hook}</span>
          </summary>
          <ol class="shelf">
            {shelf.items.map((guia) => (
              <li
                class:list={['spine', `texture-${guia.theme.texture}`]}
                style={`--g-canvas:${guia.theme.canvas};--g-ink:${guia.theme.ink};--g-soft:${guia.theme.inkSoft};--g-accent:${guia.theme.accent};--g-border:${guia.theme.border};--g-display:'${guia.theme.displayFamily}';`}
              >
                <a href={`/guias/${guia.slug}/`} class="spine-link">
                  {guia.tomo && (
                    <div class="spine-rail">
                      <span class="spine-tomo">{ROMAN[guia.tomo]}</span>
                      <span class="spine-tomo-label">Tomo</span>
                    </div>
                  )}
                  {guia.nivel && (
                    <div class="spine-rail">
                      <span class="spine-tomo spine-nivel">{guia.nivel}</span>
                      <span class="spine-tomo-label">Nivel</span>
                    </div>
                  )}
                  <div class="spine-body">
                    <h2 class="spine-title">
                      {spineTitle(guia.title, guia.collection)}
                    </h2>
                    <p class="spine-blurb">{guia.blurb}</p>
                    <div class="spine-foot">
                      <div class="spine-tags">
                        {guia.tags.map((t) => (
                          <TagPill label={t} />
                        ))}
                      </div>
                      <span class="spine-cta">Ábrela →</span>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ol>
        </details>
      ))
    }

    <!-- Recuerda qué colecciones dejaste colapsadas. Va inline y DESPUÉS de
         los <details> a propósito: corre antes del primer paint, así no se
         ve abrir-y-cerrar. Sin JS el <details> nativo sigue funcionando. -->
    <script is:inline>
      (function () {
        const KEY = 'guias-colapsadas';
        const shelves = document.querySelectorAll('.shelf-section[data-col]');
        let cerradas = [];
        try {
          const raw = JSON.parse(localStorage.getItem(KEY));
          if (Array.isArray(raw)) cerradas = raw;
        } catch {
          cerradas = [];
        }
        // Guardamos las CERRADAS, no las abiertas: una colección nueva nace
        // abierta sin que haya que tocar nada.
        const recordar = () => {
          const next = [];
          shelves.forEach((s) => {
            if (!s.open) next.push(s.dataset.col);
          });
          try {
            localStorage.setItem(KEY, JSON.stringify(next));
          } catch {
            /* modo privado o storage lleno: se pierde la memoria, no la página */
          }
        };
        shelves.forEach((d) => {
          if (cerradas.indexOf(d.dataset.col) >= 0) d.removeAttribute('open');
          d.addEventListener('toggle', recordar);
        });
      })();
    </script>
  </section>
</RealmLayout>

<style>
  /* Fuentes display de cada guía, self-hosteadas desde su carpeta (peso 700).
     Renombradas con prefijo "Guia " para no chocar si el sitio adopta alguna.
     Spectral la comparte toda la colección Polyglot. */
  @font-face {
    font-family: 'Guia Spectral';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/polyglot-ruby-c2/fonts/Spectral-Bold.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Bitter';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/design-patterns-1001/fonts/bitter-700.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Chakra Petch';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/architectures-1001/fonts/chakra-petch-700.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Space Grotesk';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/algorithms-1001/fonts/space-grotesk-700.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Fraunces';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/apis-1001/fonts/Fraunces-Bold.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Guia Playfair';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/auth-1001/fonts/playfair-display-700.woff2')
      format('woff2');
  }
  @font-face {
    font-family: 'Guia Lora';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/databases-1001/fonts/lora-700.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Guia Barlow Condensed';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/guias/messaging-1001/fonts/barlow-condensed-700.woff2')
      format('woff2');
  }

  .realm-head {
    margin-bottom: 2rem;
  }
  .realm-tag {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    color: #7fd8a6;
    margin: 0 0 0.7rem;
    text-transform: uppercase;
  }
  .realm-tag .sep {
    color: #8fa39d;
    opacity: 0.7;
  }
  .realm-tag .cur {
    animation: realm-blink 1.1s steps(1) infinite;
  }
  .realm-title {
    font-size: clamp(2.2rem, 6vw, 3.4rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0;
    color: #eef3f2;
    width: fit-content;
  }
  .realm-lede {
    margin: 0.9rem 0 0;
    max-width: 62ch;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #8fa39d;
  }

  /* ---- Estante colapsable (native <details>: cero JS, teclado gratis) ---- */
  .shelf-section {
    margin-top: 2.6rem;
  }
  /* Grid y no flex: el hook debe caer SIEMPRE en su propia fila. Con flex,
     `flex-basis:100%` lo capa el `max-width` y se colaba junto al conteo
     cuando el nombre de la colección era corto. */
  .shelf-summary {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: baseline;
    column-gap: 0.6rem;
    cursor: pointer;
    list-style: none;
    padding: 0.35rem 0;
    border-radius: 0.4rem;
  }
  .shelf-summary::-webkit-details-marker {
    display: none;
  }
  .shelf-summary:focus-visible {
    outline: 2px solid #7fd8a6;
    outline-offset: 4px;
  }
  .shelf-name {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: #eef3f2;
  }
  .shelf-name .sep {
    color: #8fa39d;
    opacity: 0.7;
  }
  .shelf-count {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.68rem;
    color: #7fd8a6;
    opacity: 0.8;
  }
  .shelf-chevron {
    width: 0.85rem;
    height: 0.85rem;
    flex: none;
    align-self: center;
    color: #8fa39d;
    transition: transform 160ms ease;
  }
  .shelf-section[open] > .shelf-summary .shelf-chevron {
    transform: rotate(90deg);
  }
  .shelf-summary:hover .shelf-chevron {
    color: #7fd8a6;
  }
  /* Segunda fila del summary: cae bajo el nombre de la colección y se queda
     visible aunque el estante esté cerrado. */
  .shelf-hook {
    grid-column: 1 / -1;
    margin: 0.35rem 0 0;
    font-size: 0.85rem;
    line-height: 1.5;
    color: #8fa39d;
    max-width: 62ch;
  }

  /* ---- El estante: rows lomo-de-libro ---- */
  .shelf {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Cada spine adopta la paleta oscura + textura + fuente display de su guía. */
  .spine {
    border: 1px solid var(--g-border);
    border-radius: 0.9rem;
    background-color: var(--g-canvas);
    overflow: hidden;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  /* ---- Texturas por guía (mismas fórmulas que las portadas) ---- */
  .spine.texture-grid {
    background-image:
      linear-gradient(
        color-mix(in srgb, var(--g-accent) 8%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--g-accent) 8%, transparent) 1px,
        transparent 1px
      );
    background-size: 22px 22px;
  }
  .spine.texture-grain {
    background-image: repeating-linear-gradient(
      90deg,
      color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
      transparent 1px 46px
    );
  }
  .spine.texture-stripes {
    background-image: repeating-linear-gradient(
      45deg,
      color-mix(in srgb, var(--g-accent) 7%, transparent) 0 2px,
      transparent 2px 26px
    );
  }
  .spine.texture-arcs {
    background-image: repeating-radial-gradient(
      circle at 0 130%,
      color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
      transparent 1px 22px
    );
  }
  .spine.texture-rules {
    background-image: repeating-linear-gradient(
      0deg,
      color-mix(in srgb, var(--g-accent) 8%, transparent) 0 1px,
      transparent 1px 26px
    );
  }
  .spine.texture-facets {
    background-image:
      repeating-linear-gradient(
        60deg,
        color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
        transparent 1px 34px
      ),
      repeating-linear-gradient(
        -60deg,
        color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
        transparent 1px 34px
      );
  }
  .spine.texture-lattice {
    background-image:
      repeating-linear-gradient(
        30deg,
        color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
        transparent 1px 38px
      ),
      repeating-linear-gradient(
        -30deg,
        color-mix(in srgb, var(--g-accent) 7%, transparent) 0 1px,
        transparent 1px 38px
      );
  }
  .spine.texture-crosshatch {
    background-image:
      repeating-linear-gradient(
        0deg,
        color-mix(in srgb, var(--g-accent) 9%, transparent) 0 1px,
        transparent 1px 11px
      ),
      repeating-linear-gradient(
        90deg,
        color-mix(in srgb, var(--g-accent) 9%, transparent) 0 1px,
        transparent 1px 11px
      );
  }
  .spine.texture-twill {
    background-image: repeating-linear-gradient(
      135deg,
      color-mix(in srgb, var(--g-accent) 8%, transparent) 0 1px,
      transparent 1px 30px
    );
  }
  /* foquitos de marquesina: dos hileras desfasadas, como la portada de la guía */
  .spine.texture-bulbs {
    background-image:
      radial-gradient(
        circle,
        color-mix(in srgb, var(--g-accent) 22%, transparent) 1.2px,
        transparent 1.3px
      ),
      radial-gradient(
        circle,
        color-mix(in srgb, var(--g-accent) 22%, transparent) 1.2px,
        transparent 1.3px
      );
    background-size:
      20px 40px,
      20px 40px;
    background-position:
      0 0,
      10px 20px;
  }
  .spine.texture-morse {
    background-image:
      repeating-linear-gradient(
        0deg,
        var(--g-canvas) 0 27px,
        transparent 27px 28px
      ),
      repeating-linear-gradient(
        90deg,
        color-mix(in srgb, var(--g-accent) 12%, transparent) 0 10px,
        transparent 10px 18px,
        color-mix(in srgb, var(--g-accent) 12%, transparent) 18px 21px,
        transparent 21px 38px
      );
  }

  .spine:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--g-accent) 55%, var(--g-border));
    box-shadow: 0 16px 40px -20px rgba(0, 0, 0, 0.7);
  }

  .spine-link {
    display: flex;
    gap: clamp(0.9rem, 3vw, 1.6rem);
    align-items: stretch;
    padding: clamp(1.1rem, 3vw, 1.5rem) clamp(1.2rem, 3.5vw, 1.7rem);
    text-decoration: none;
    color: var(--g-ink);
  }

  .spine-rail {
    flex: none;
    width: 3.2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.15rem;
    border-right: 1px solid color-mix(in srgb, var(--g-border) 70%, transparent);
    padding-right: clamp(0.6rem, 2vw, 1rem);
  }
  .spine-tomo {
    /* Serif fija para el numeral: sin serifas, II/III se ven como barras. */
    font-family: Georgia, 'Iowan Old Style', 'Times New Roman', serif;
    font-weight: 700;
    font-size: 1.9rem;
    line-height: 1;
    color: var(--g-accent);
  }
  /* El nivel CEFR es alfanumérico corto (C2): mono, como código de escala. */
  .spine-nivel {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 1.5rem;
    letter-spacing: 0.04em;
  }
  .spine-tomo-label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--g-soft);
  }

  .spine-body {
    flex: 1;
    min-width: 0;
  }
  .spine-title {
    font-family: var(--g-display), Georgia, serif;
    font-weight: 700;
    font-size: clamp(1.3rem, 3.4vw, 1.85rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--g-ink);
  }
  .spine-blurb {
    margin: 0.55rem 0 0;
    font-size: 0.86rem;
    line-height: 1.55;
    color: var(--g-soft);
  }
  .spine-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 0.95rem;
  }
  .spine-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .spine-cta {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--g-accent);
    white-space: nowrap;
  }

  @media (max-width: 560px) {
    .spine-link {
      flex-direction: column;
    }
    .spine-rail {
      flex-direction: row;
      width: auto;
      justify-content: flex-start;
      gap: 0.5rem;
      border-right: 0;
      border-bottom: 1px solid
        color-mix(in srgb, var(--g-border) 70%, transparent);
      padding: 0 0 0.6rem;
    }
    .spine-tomo {
      font-size: 1.4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .realm-tag .cur {
      animation: none;
    }
    .spine,
    .shelf-chevron {
      transition: none;
    }
    .spine:hover {
      transform: none;
    }
  }

  /* El tag-pill del sitio hereda tokens claros y una animación de aterrizaje
     que dispara un script de BaseLayout (que aquí no existe): dentro del spine
     lo re-tiño a la paleta de la guía y lo dejo visible sin animación. */
  .spine :global(.tag-pill) {
    background: color-mix(in srgb, var(--g-accent) 14%, transparent);
    border-color: color-mix(in srgb, var(--g-accent) 32%, transparent);
    color: var(--g-ink);
    animation: none;
    opacity: 1;
    transform: none;
  }
</style>
