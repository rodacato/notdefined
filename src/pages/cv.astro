---
import BaseLayout from '../layouts/BaseLayout.astro';
import { cv } from '../data/cv';
---

<BaseLayout
  title={`CV — ${cv.name}`}
  description="Curriculum de Adrian Castillo."
>
  <article class="cv">
    <header class="cv-head">
      <div>
        <h1 class="cv-name">{cv.name}</h1>
        <p class="cv-title">{cv.title}</p>
        <p class="cv-lane">{cv.lane}</p>
      </div>
      <button class="cv-download" type="button" data-print>Descargar PDF</button
      >
    </header>

    <p class="cv-contact">
      {cv.location} · <a href={`mailto:${cv.email}`}>{cv.email}</a>
      {
        cv.links.map((link) => (
          <>
            {' · '}
            <a href={link.href} target="_blank" rel="noopener noreferrer">
              {link.label}
            </a>
          </>
        ))
      }
    </p>

    <p class="cv-summary">{cv.summary}</p>

    <section class="cv-section">
      <h2 class="cv-section-title">Experience</h2>
      {
        cv.experience.map((job) => (
          <div class="cv-job">
            <div class="cv-job-head">
              <span class="cv-job-company">{job.company}</span>
              <span class="cv-job-period">{job.period}</span>
            </div>
            <div class="cv-job-sub">
              <span class="cv-job-role">{job.role}</span>
              <span class="cv-job-loc">{job.location}</span>
            </div>
            <ul class="cv-job-highlights">
              {job.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
            <p class="cv-job-stack">{job.stack.join(' · ')}</p>
          </div>
        ))
      }
    </section>

    <div class="cv-grid">
      <section class="cv-section">
        <h2 class="cv-section-title">Education</h2>
        {
          cv.education.map((ed) => (
            <p class="cv-line">
              <strong>{ed.degree}</strong>
              <br />
              {ed.school} · {ed.period}
            </p>
          ))
        }
      </section>

      <section class="cv-section">
        <h2 class="cv-section-title">Awards</h2>
        {cv.awards.map((a) => <p class="cv-line">{a}</p>)}
      </section>

      <section class="cv-section">
        <h2 class="cv-section-title">Languages</h2>
        {
          cv.languages.map((l) => (
            <p class="cv-line">
              {l.name} — {l.level}
            </p>
          ))
        }
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .cv {
    max-width: 44rem;
  }

  .cv-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .cv-name {
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0;
  }

  .cv-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-accent);
    margin: 0.25rem 0 0;
  }

  .cv-lane {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin: 0.1rem 0 0;
  }

  .cv-download {
    flex-shrink: 0;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.45rem 0.9rem;
    cursor: pointer;
    transition:
      border-color 150ms ease,
      color 150ms ease;
  }
  .cv-download:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .cv-contact {
    font-size: 0.82rem;
    color: var(--color-muted);
    margin: 1rem 0 0;
    line-height: 1.6;
  }
  .cv-contact a {
    color: var(--color-muted);
    text-decoration: none;
  }
  .cv-contact a:hover {
    color: var(--color-accent);
  }

  .cv-summary {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.7;
    margin: 1.25rem 0 0;
  }

  .cv-section {
    margin-top: 2rem;
  }

  .cv-section-title {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.4rem;
    margin: 0 0 1rem;
  }

  .cv-job {
    margin-bottom: 1.5rem;
    break-inside: avoid;
  }

  .cv-job-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .cv-job-company {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .cv-job-period {
    font-size: 0.78rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cv-job-sub {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.1rem;
  }

  .cv-job-role {
    font-size: 0.85rem;
    color: var(--color-accent);
  }

  .cv-job-loc {
    font-size: 0.78rem;
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .cv-job-highlights {
    margin: 0.6rem 0 0;
    padding-left: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .cv-job-highlights li {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.55;
  }

  .cv-job-stack {
    font-size: 0.78rem;
    color: var(--color-muted);
    margin: 0.5rem 0 0;
    font-family: var(--font-mono, monospace);
  }

  .cv-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 1.5rem;
  }

  .cv-line {
    font-size: 0.85rem;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0 0 0.5rem;
  }
</style>

<style is:global>
  @media print {
    .site-header,
    .site-footer,
    .cursor-glow,
    .cv-download {
      display: none !important;
    }
    main {
      padding: 0 !important;
    }
    body {
      background: #fff !important;
    }
    .cv-job {
      break-inside: avoid;
    }
  }
</style>

<script>
  document.querySelector('[data-print]')?.addEventListener('click', () => {
    window.print();
  });
</script>
