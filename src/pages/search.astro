---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => ({
    slug: post.slug,
    title: post.data.title,
    description: post.data.description,
    tags: post.data.tags,
    date: post.data.pubDate.toLocaleDateString('es-MX', { year: 'numeric', month: 'short', day: 'numeric' }),
  }));
---

<BaseLayout title="Search — notdefined.dev" description="Busca en todos los posts de notdefined.dev.">

  <header class="mb-8">
    <p class="label mb-2">Buscar</p>
    <h1 class="page-title">Search</h1>
  </header>

  <div class="search-wrap">
    <input
      id="search-input"
      type="search"
      placeholder="Busca por título, descripción o tag…"
      class="search-input"
      autofocus
    />
  </div>

  <p id="search-count" class="search-count"></p>

  <ul id="results" class="post-list"></ul>

  <p id="search-empty" class="search-empty hidden">No hay resultados para esta búsqueda.</p>

</BaseLayout>

<script is:inline define:vars={{ posts }}>
  const input = document.getElementById('search-input');
  const list = document.getElementById('results');
  const count = document.getElementById('search-count');
  const empty = document.getElementById('search-empty');

  function formatDate(str) { return str; }

  function render(filtered) {
    list.innerHTML = '';
    empty.classList.add('hidden');

    if (filtered.length === 0 && input.value.trim()) {
      empty.classList.remove('hidden');
      count.textContent = '';
      return;
    }

    count.textContent = input.value.trim()
      ? `${filtered.length} resultado${filtered.length !== 1 ? 's' : ''}`
      : '';

    filtered.forEach((post, i) => {
      const li = document.createElement('li');
      li.className = i > 0 ? 'post-item bordered' : 'post-item';
      li.innerHTML = `
        <a href="/blog/${post.slug}/" class="post-link">
          <h3 class="post-title">${post.title}</h3>
          <p class="post-desc">${post.description}</p>
          <div class="post-footer">
            <div class="tag-row">${post.tags.map(t => `<span class="tag">${t}</span>`).join('')}</div>
            <span class="post-meta">${post.date}</span>
          </div>
        </a>`;
      list.appendChild(li);
    });
  }

  function search(q) {
    if (!q.trim()) { render([]); return; }
    const terms = q.toLowerCase().split(/\s+/).filter(Boolean);
    const results = posts.filter(post => {
      const haystack = `${post.title} ${post.description} ${post.tags.join(' ')}`.toLowerCase();
      return terms.every(t => haystack.includes(t));
    });
    render(results);
  }

  input.addEventListener('input', (e) => search(e.target.value));
</script>

<style>
  .label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .page-title {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .search-wrap { margin-bottom: 1rem; }
  .search-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    font-family: inherit;
    color: var(--color-text);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    outline: none;
    transition: border-color 150ms ease;
  }
  .search-input:focus { border-color: var(--color-accent); }
  .search-input::placeholder { color: var(--color-muted); opacity: 0.6; }

  .search-count {
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
    min-height: 1.2em;
  }
  .search-empty {
    font-size: 0.9rem;
    color: var(--color-muted);
    padding: 2rem 0;
    text-align: center;
  }
  .hidden { display: none; }

  .post-list {
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    overflow: hidden;
  }
  .post-list:empty { display: none; }
  .post-item.bordered { border-top: 1px solid var(--color-border); }

  .post-link {
    display: block;
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: background-color 120ms ease;
  }
  .post-link:hover { background-color: var(--color-surface); }

  .post-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    margin: 0 0 0.25rem;
    transition: color 120ms ease;
  }
  .post-link:hover .post-title { color: var(--color-accent); }

  .post-desc {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0 0 0.625rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .tag-row { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .tag {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    padding: 0.15em 0.5em;
    border-radius: 0.2rem;
    background-color: var(--color-surface-2);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    white-space: nowrap;
  }
  .post-meta {
    font-size: 0.72rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0.8;
  }
</style>
