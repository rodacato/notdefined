---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const posts = entries.map((post) => ({
  slug: post.slug,
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags,
  date: post.data.pubDate.toLocaleDateString('es-MX', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  }),
}));

const tagCounts: Record<string, number> = {};
for (const post of posts) {
  for (const tag of post.tags) tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
}
const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([tag]) => tag);
---

<BaseLayout
  title="Buscar — notdefined.dev"
  description="Busca en todos los posts de notdefined.dev."
  hideSearch
>
  <h1 class="visually-hidden">Buscar</h1>

  <div class="search-wrap">
    <svg
      class="search-icon"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="7"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <input
      id="search-input"
      type="search"
      placeholder="Busca por título, descripción o tag…"
      class="search-input"
      aria-label="Buscar en los posts"
      autocomplete="off"
      autofocus
    />
  </div>

  <p id="search-count" class="search-count"></p>
  <ul id="results" class="card-list"></ul>

  <div id="suggestions" class="suggestions">
    <p id="suggestions-title" class="suggestions-title">Explora por tema</p>
    <div class="suggestions-tags">
      {
        topTags.map((tag) => (
          <button type="button" class="suggest-tag" data-tag={tag}>
            {tag}
          </button>
        ))
      }
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ posts }}>
  /* global posts */
  const input = document.getElementById('search-input');
  const list = document.getElementById('results');
  const count = document.getElementById('search-count');
  const suggestions = document.getElementById('suggestions');
  const suggestionsTitle = document.getElementById('suggestions-title');

  function createTag(label) {
    const tag = document.createElement('span');
    tag.className = 'tag-pill';
    tag.textContent = label;
    return tag;
  }

  function showSuggestions(title) {
    suggestionsTitle.textContent = title;
    suggestions.style.display = '';
  }

  function renderResults(filtered) {
    list.innerHTML = '';
    filtered.forEach((post) => {
      const item = document.createElement('li');
      item.className = 'card-list-item post-item';

      const link = document.createElement('a');
      link.className = 'post-link';
      link.href = `/blog/${post.slug}/`;

      const title = document.createElement('h3');
      title.className = 'post-title';
      title.textContent = post.title;

      const desc = document.createElement('p');
      desc.className = 'post-desc';
      desc.textContent = post.description;

      const footer = document.createElement('div');
      footer.className = 'post-footer';

      const tags = document.createElement('div');
      tags.className = 'tag-row';
      post.tags.forEach((tag) => tags.appendChild(createTag(tag)));

      const date = document.createElement('span');
      date.className = 'post-meta';
      date.textContent = post.date;

      footer.appendChild(tags);
      footer.appendChild(date);
      link.appendChild(title);
      link.appendChild(desc);
      link.appendChild(footer);
      item.appendChild(link);
      list.appendChild(item);
    });
  }

  function search(q) {
    const query = q.trim();

    if (!query) {
      list.innerHTML = '';
      count.textContent = '';
      showSuggestions('Explora por tema');
      return;
    }

    const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
    const results = posts.filter((post) => {
      const haystack =
        `${post.title} ${post.description} ${post.tags.join(' ')}`.toLowerCase();
      return terms.every((t) => haystack.includes(t));
    });

    if (results.length === 0) {
      list.innerHTML = '';
      count.textContent = `Nada para «${query}».`;
      showSuggestions('Prueba con estos temas');
      return;
    }

    suggestions.style.display = 'none';
    count.textContent = `${results.length} resultado${results.length !== 1 ? 's' : ''}`;
    renderResults(results);
  }

  input.addEventListener('input', (e) => search(e.target.value));

  document.querySelectorAll('.suggest-tag').forEach((btn) => {
    btn.addEventListener('click', () => {
      input.value = btn.dataset.tag;
      input.focus();
      search(btn.dataset.tag);
    });
  });

  const initialQuery = new URLSearchParams(window.location.search).get('q');
  if (initialQuery) {
    input.value = initialQuery;
    search(initialQuery);
  }
</script>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .search-wrap {
    position: relative;
    margin-bottom: 1.25rem;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1.1rem;
    height: 1.1rem;
    color: var(--color-muted);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 0.9rem 1rem 0.9rem 2.7rem;
    font-size: 1rem;
    font-family: inherit;
    color: var(--color-text);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.7rem;
    outline: none;
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease;
  }
  .search-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px
      color-mix(in oklab, var(--color-accent) 15%, transparent);
  }
  .search-input::placeholder {
    color: var(--color-muted);
    opacity: 0.7;
  }

  .search-count {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
    min-height: 1.2em;
  }

  .card-list:empty {
    display: none;
  }

  .suggestions {
    margin-top: 1.5rem;
  }

  .suggestions-title {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 0.85rem;
  }

  .suggestions-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .suggest-tag {
    font-family: inherit;
    font-size: 0.82rem;
    color: var(--color-text);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.4rem 0.85rem;
    cursor: pointer;
    transition:
      border-color 150ms ease,
      color 150ms ease,
      background-color 150ms ease;
  }
  .suggest-tag:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background-color: var(--color-surface-2);
  }

  .post-link {
    display: block;
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: background-color 120ms ease;
  }
  .post-link:hover {
    background-color: var(--color-surface);
  }

  .post-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    margin: 0 0 0.25rem;
    transition: color 120ms ease;
  }
  .post-link:hover .post-title {
    color: var(--color-accent);
  }

  .post-desc {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0 0 0.625rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .post-meta {
    font-size: 0.72rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0.8;
  }
</style>
