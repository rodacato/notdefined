---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => ({
    slug: post.slug,
    title: post.data.title,
    description: post.data.description,
    tags: post.data.tags,
    date: post.data.pubDate.toLocaleDateString('es-MX', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    }),
  }));
---

<BaseLayout
  title="Buscar — notdefined.dev"
  description="Busca en todos los posts de notdefined.dev."
>
  <PageHeader label="Buscar" title="Buscar" />

  <div class="search-wrap">
    <input
      id="search-input"
      type="search"
      placeholder="Busca por título, descripción o tag…"
      class="search-input"
      autofocus
    />
  </div>

  <p id="search-count" class="search-count"></p>
  <ul id="results" class="card-list"></ul>
  <p id="search-empty" class="search-empty hidden">
    No hay resultados para esta búsqueda.
  </p>
</BaseLayout>

<script is:inline define:vars={{ posts }}>
  /* global posts */
  const input = document.getElementById('search-input');
  const list = document.getElementById('results');
  const count = document.getElementById('search-count');
  const empty = document.getElementById('search-empty');

  function createTag(label) {
    const tag = document.createElement('span');
    tag.className = 'tag-pill';
    tag.textContent = label;
    return tag;
  }

  function render(filtered) {
    list.innerHTML = '';
    empty.classList.add('hidden');

    const query = input.value.trim();
    if (filtered.length === 0 && query) {
      empty.classList.remove('hidden');
      count.textContent = '';
      return;
    }

    count.textContent = query
      ? `${filtered.length} resultado${filtered.length !== 1 ? 's' : ''}`
      : '';

    filtered.forEach((post) => {
      const item = document.createElement('li');
      item.className = 'card-list-item post-item';

      const link = document.createElement('a');
      link.className = 'post-link';
      link.href = `/blog/${post.slug}/`;

      const title = document.createElement('h3');
      title.className = 'post-title';
      title.textContent = post.title;

      const desc = document.createElement('p');
      desc.className = 'post-desc';
      desc.textContent = post.description;

      const footer = document.createElement('div');
      footer.className = 'post-footer';

      const tags = document.createElement('div');
      tags.className = 'tag-row';
      post.tags.forEach((tag) => tags.appendChild(createTag(tag)));

      const date = document.createElement('span');
      date.className = 'post-meta';
      date.textContent = post.date;

      footer.appendChild(tags);
      footer.appendChild(date);
      link.appendChild(title);
      link.appendChild(desc);
      link.appendChild(footer);
      item.appendChild(link);
      list.appendChild(item);
    });
  }

  function search(q) {
    if (!q.trim()) {
      render([]);
      return;
    }
    const terms = q.toLowerCase().split(/\s+/).filter(Boolean);
    const results = posts.filter((post) => {
      const haystack =
        `${post.title} ${post.description} ${post.tags.join(' ')}`.toLowerCase();
      return terms.every((t) => haystack.includes(t));
    });
    render(results);
  }

  input.addEventListener('input', (e) => search(e.target.value));
</script>

<style>
  .search-wrap {
    margin-bottom: 1rem;
  }

  .search-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    font-family: inherit;
    color: var(--color-text);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    outline: none;
    transition: border-color 150ms ease;
  }
  .search-input:focus {
    border-color: var(--color-accent);
  }
  .search-input::placeholder {
    color: var(--color-muted);
    opacity: 0.6;
  }

  .search-count {
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
    min-height: 1.2em;
  }

  .search-empty {
    font-size: 0.9rem;
    color: var(--color-muted);
    padding: 2rem 0;
    text-align: center;
  }

  .hidden {
    display: none;
  }
  .card-list:empty {
    display: none;
  }

  .post-link {
    display: block;
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: background-color 120ms ease;
  }
  .post-link:hover {
    background-color: var(--color-surface);
  }

  .post-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    margin: 0 0 0.25rem;
    transition: color 120ms ease;
  }
  .post-link:hover .post-title {
    color: var(--color-accent);
  }

  .post-desc {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0 0 0.625rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .post-meta {
    font-size: 0.72rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0.8;
  }
</style>
