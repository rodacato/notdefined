---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  )
  .slice(0, 5);

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<BaseLayout title="notdefined.dev" description="Sitio personal y blog de Adrian Castillo — desarrollador full-stack escribiendo sobre Ruby, JavaScript, backend e IA.">

  <!-- Hero -->
  <section class="hero">
    <p class="hero-label">notdefined.dev</p>
    <h1 class="hero-title">Ruby, backend, IA.</h1>
    <p class="hero-desc">
      Escribo sobre lo que realmente construyo — arquitectura, decisiones de código,
      experimentos con LLMs, y las cosas que aprendo en el camino.
      <a href="/now/" class="hero-link">¿Qué estoy haciendo ahora?</a>
    </p>
    <div class="hero-meta">
      <span class="hero-meta-item">Adrian Castillo</span>
      <span class="hero-sep">·</span>
      <span class="hero-meta-item">Full-stack · 10+ años</span>
      <span class="hero-sep">·</span>
      <a href="/projects/" class="hero-meta-link">Proyectos →</a>
    </div>
  </section>

  <!-- Recent posts -->
  <section>
    <div class="section-header">
      <h2 class="section-label">Posts recientes</h2>
      <a href="/blog/" class="section-link">Todos los posts →</a>
    </div>

    <ul class="post-list">
      {posts.map((post: CollectionEntry<'blog'>, i: number) => (
        <li class={i > 0 ? 'post-list-item bordered' : 'post-list-item'}>
          <a href={`/blog/${post.slug}/`} class="post-link">
            <span class="post-title">{post.data.title}</span>
            <span class="post-date">{formatDate(post.data.pubDate)}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

</BaseLayout>

<style>
  .hero {
    margin-bottom: 4rem;
  }
  .hero-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }
  .hero-title {
    font-size: clamp(1.8rem, 5vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .hero-desc {
    color: var(--color-muted);
    max-width: 38rem;
    line-height: 1.7;
    font-size: 0.9375rem;
    margin-bottom: 1.25rem;
  }
  .hero-link {
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 150ms ease;
  }
  .hero-link:hover { opacity: 0.7; }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .hero-meta-item {
    font-size: 0.8rem;
    color: var(--color-muted);
  }
  .hero-sep {
    font-size: 0.8rem;
    color: var(--color-border);
  }
  .hero-meta-link {
    font-size: 0.8rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 150ms ease;
  }
  .hero-meta-link:hover { opacity: 0.7; }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .section-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .section-link {
    font-size: 0.8rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 150ms ease;
  }
  .section-link:hover { opacity: 0.7; }

  .post-list {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .post-list-item.bordered {
    border-top: 1px solid var(--color-border);
  }
  .post-link {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    transition: background-color 150ms ease;
    text-decoration: none;
  }
  .post-link:hover { background-color: var(--color-surface); }
  .post-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    transition: color 150ms ease;
  }
  .post-link:hover .post-title { color: var(--color-accent); }
  .post-date {
    font-size: 0.78rem;
    color: var(--color-muted);
    white-space: nowrap;
    padding-top: 0.1rem;
    flex-shrink: 0;
  }
</style>
