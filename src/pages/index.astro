---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort(
    (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
      b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  )
  .slice(0, 5);

const tils = (await getCollection('til'))
  .sort(
    (a: CollectionEntry<'til'>, b: CollectionEntry<'til'>) =>
      b.data.date.valueOf() - a.data.date.valueOf(),
  )
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="notdefined.dev"
  description="Sitio personal y blog de Adrian Castillo — desarrollador full-stack escribiendo sobre Ruby, JavaScript, backend e IA."
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-gradient" aria-hidden="true"></div>
    <p class="hero-label">notdefined.dev</p>
    <h1 class="hero-title">Ruby, backend, IA.</h1>
    <p class="hero-desc">
      Escribo sobre lo que realmente construyo — arquitectura, decisiones de
      código, experimentos con LLMs, y las cosas que aprendo en el camino.
      <a href="/now/" class="hero-link">¿Qué estoy haciendo ahora?</a>
    </p>
    <div class="hero-meta">
      <span class="hero-meta-item">Adrian Castillo</span>
      <span class="hero-sep">·</span>
      <span class="hero-meta-item">Full-stack · 10+ años</span>
      <span class="hero-sep">·</span>
      <a href="/projects/" class="hero-meta-link">Proyectos →</a>
    </div>
  </section>

  <!-- Recent posts -->
  <section data-parallax="0.02">
    <div class="section-header">
      <h2 class="section-label">Posts recientes</h2>
      <a href="/blog/" class="section-link">Todos los posts →</a>
    </div>

    <ul class="post-list">
      {
        posts.map((post, i) => (
          <li class={`post-list-item fade-in-item${i > 0 ? ' bordered' : ''}`}>
            <a href={`/blog/${post.slug}/`} class="post-link">
              <span class="post-title">{post.data.title}</span>
              <span class="post-date">{formatDate(post.data.pubDate)}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Recent TILs -->
  <section class="til-section" data-parallax="0.035">
    <div class="section-header">
      <h2 class="section-label">TIL recientes</h2>
      <a href="/til/" class="section-link">Ver todos →</a>
    </div>

    <ul class="post-list">
      {
        tils.map((entry, i) => (
          <li class={`post-list-item fade-in-item${i > 0 ? ' bordered' : ''}`}>
            <a href={`/til/${entry.slug}/`} class="post-link">
              <span class="post-title">{entry.data.title}</span>
              <span class="post-date">{formatDate(entry.data.date)}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    margin-bottom: 4rem;
  }

  .hero-gradient {
    position: absolute;
    inset: -4rem -6rem;
    z-index: -1;
    opacity: 0.3;
    background:
      radial-gradient(
        ellipse 60% 50% at 20% 30%,
        oklch(75% 0.14 275 / 0.18),
        transparent
      ),
      radial-gradient(
        ellipse 50% 60% at 80% 60%,
        oklch(70% 0.09 250 / 0.14),
        transparent
      ),
      radial-gradient(
        ellipse 70% 40% at 50% 80%,
        oklch(80% 0.07 290 / 0.1),
        transparent
      );
    background-size: 200% 200%;
    animation: mesh-drift 20s ease-in-out infinite alternate;
    filter: blur(60px);
    pointer-events: none;
  }

  @keyframes mesh-drift {
    0% {
      background-position:
        0% 0%,
        100% 100%,
        50% 50%;
    }
    50% {
      background-position:
        40% 60%,
        60% 20%,
        30% 80%;
    }
    100% {
      background-position:
        80% 30%,
        20% 80%,
        70% 20%;
    }
  }
  .hero-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }
  .hero-title {
    font-size: clamp(1.8rem, 5vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .hero-desc {
    color: var(--color-muted);
    max-width: 38rem;
    line-height: 1.7;
    font-size: 0.9375rem;
    margin-bottom: 1.25rem;
  }
  .hero-link {
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 150ms ease;
  }
  .hero-link:hover {
    opacity: 0.7;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .hero-meta-item {
    font-size: 0.8rem;
    color: var(--color-muted);
  }
  .hero-sep {
    font-size: 0.8rem;
    color: var(--color-border);
  }
  .hero-meta-link {
    font-size: 0.8rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 150ms ease;
  }
  .hero-meta-link:hover {
    opacity: 0.7;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .section-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .section-link {
    font-size: 0.8rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 150ms ease;
  }
  .section-link:hover {
    opacity: 0.7;
  }
  .til-section {
    margin-top: 3rem;
  }

  .post-list {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .post-list-item.bordered {
    border-top: 1px solid var(--color-border);
  }
  .post-link {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    transition: background-color 150ms ease;
    text-decoration: none;
  }
  .post-link:hover {
    background-color: var(--color-surface);
  }
  .post-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    transition: color 150ms ease;
  }
  .post-link:hover .post-title {
    color: var(--color-accent);
  }
  .post-date {
    font-size: 0.78rem;
    color: var(--color-muted);
    white-space: nowrap;
    padding-top: 0.1rem;
    flex-shrink: 0;
  }
</style>
