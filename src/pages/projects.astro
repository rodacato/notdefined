---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CardList from '../components/CardList.astro';
import TagPill from '../components/TagPill.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) =>
    a.data.order - b.data.order || a.data.name.localeCompare(b.data.name),
);
---

<BaseLayout
  title="Proyectos — notdefined.dev"
  description="Proyectos y experimentos de Adrian Castillo."
  width="wide"
>
  <PageHeader
    label="Trabajo"
    title="Proyectos"
    description="Cosas que construyo, experimento o sigo desarrollando."
  />

  <CardList>
    {
      projects.map((project) => (
        <li
          class="card-list-item project-item fade-in-item"
          style={`--accent: ${project.data.accent ?? '#6366f1'}`}
        >
          {project.data.image && (
            <img
              class="project-shot"
              src={project.data.image}
              alt={`Captura de ${project.data.name}`}
              loading="lazy"
            />
          )}

          <div class="project-top">
            <span class="project-icon" aria-hidden={!project.data.icon}>
              {project.data.icon ? (
                <img
                  src={project.data.icon}
                  alt={`Logo de ${project.data.name}`}
                />
              ) : (
                project.data.name.charAt(0)
              )}
            </span>
            <div class="project-id">
              <h2 class="project-name">{project.data.name}</h2>
              <p class="project-tagline">{project.data.tagline}</p>
            </div>
            <a
              href={project.data.repo}
              target="_blank"
              rel="noopener noreferrer"
              class="project-github"
            >
              GitHub ↗
            </a>
          </div>

          <p class="project-desc">{project.data.product}</p>

          <div class="project-footer">
            {project.data.stack.map((item: string) => (
              <TagPill label={item} />
            ))}
          </div>

          <details class="project-tech">
            <summary>Cómo está construido</summary>
            <p>{project.data.technical}</p>
          </details>

          {project.data.url && (
            <a
              href={project.data.url}
              target="_blank"
              rel="noopener noreferrer"
              class="project-cta"
            >
              Probar {project.data.name} →
            </a>
          )}
        </li>
      ))
    }
  </CardList>
</BaseLayout>

<style>
  .project-item {
    padding: 0;
    overflow: hidden;
    transition:
      border-color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }
  .project-item:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -12px
      color-mix(in oklab, var(--accent) 50%, transparent);
  }

  .project-shot {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-bottom: 1px solid var(--color-border);
  }

  .project-top {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1.5rem 1.5rem 0;
  }

  .project-icon {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    border-radius: 0.6rem;
    background-color: var(--accent);
    color: #fff;
    font-size: 1.1rem;
    font-weight: 700;
    overflow: hidden;
  }
  .project-icon:has(img) {
    background-color: #fff;
    border: 1px solid var(--color-border);
    padding: 5px;
  }
  .project-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .project-id {
    flex: 1;
    min-width: 0;
  }

  .project-name {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
  }

  .project-tagline {
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 500;
    margin: 0.15rem 0 0;
    line-height: 1.4;
  }

  .project-github {
    flex-shrink: 0;
    font-size: 0.78rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .project-github:hover {
    color: var(--accent);
  }

  .project-desc {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.65;
    margin: 0.9rem 0 0;
    padding: 0 1.5rem;
  }

  .project-footer {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
    padding: 1rem 1.5rem 0;
  }

  .project-tech {
    margin: 1rem 0 0;
    border-top: 1px solid var(--color-border);
  }
  .project-tech summary {
    list-style: none;
    cursor: pointer;
    padding: 0.85rem 1.5rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-muted);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: color 150ms ease;
  }
  .project-tech summary::-webkit-details-marker {
    display: none;
  }
  .project-tech summary::before {
    content: '▸';
    color: var(--accent);
    transition: transform 150ms ease;
  }
  .project-tech[open] summary::before {
    transform: rotate(90deg);
  }
  .project-tech summary:hover {
    color: var(--color-text);
  }
  .project-tech p {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.65;
    margin: 0;
    padding: 0 1.5rem 0.25rem;
  }

  .project-cta {
    display: inline-flex;
    align-items: center;
    margin: 0.5rem 1.5rem 1.5rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    background-color: var(--accent);
    color: #fff;
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    transition:
      opacity 150ms ease,
      transform 150ms ease;
  }
  .project-cta:hover {
    opacity: 0.9;
    transform: translateX(2px);
  }
</style>
