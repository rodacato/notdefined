---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CardList from '../components/CardList.astro';
import TagPill from '../components/TagPill.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) =>
    a.data.order - b.data.order || a.data.name.localeCompare(b.data.name),
);
---

<BaseLayout
  title="Proyectos — notdefined.dev"
  description="Proyectos y experimentos de Adrian Castillo."
>
  <PageHeader
    label="Trabajo"
    title="Proyectos"
    description="Cosas que construyo, experimento o sigo desarrollando."
  />

  <CardList>
    {
      projects.map((project) => (
        <li class="card-list-item project-item fade-in-item">
          <div class="project-header">
            <h2 class="project-name">{project.data.name}</h2>
            <div class="project-links">
              {project.data.url && (
                <a
                  href={project.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="project-link"
                >
                  sitio ↗
                </a>
              )}
              <a
                href={project.data.repo}
                target="_blank"
                rel="noopener noreferrer"
                class="project-link"
              >
                GitHub ↗
              </a>
            </div>
          </div>
          <p class="project-tagline">{project.data.tagline}</p>
          <p class="project-desc">{project.data.product}</p>
          <p class="project-tech">{project.data.technical}</p>
          <div class="project-footer">
            {project.data.stack.map((item: string) => (
              <TagPill label={item} />
            ))}
          </div>
        </li>
      ))
    }
  </CardList>
</BaseLayout>

<style>
  .project-item {
    padding: 1.5rem;
  }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .project-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .project-link {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .project-link:hover {
    color: var(--color-accent);
  }

  .project-tagline {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .project-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }

  .project-tech {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0 0 0.875rem;
    padding-left: 0.75rem;
    border-left: 2px solid var(--color-border);
  }

  .project-footer {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
  }
</style>
