---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import TagPill from '../components/TagPill.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) =>
    a.data.order - b.data.order || a.data.name.localeCompare(b.data.name),
);
---

<BaseLayout
  title="Proyectos — notdefined.dev"
  description="Proyectos y experimentos de Adrian Castillo."
  width="wide"
>
  <PageHeader
    label="Trabajo"
    title="Proyectos"
    description="Cosas que construyo, experimento o sigo desarrollando."
  />

  <div class="projects-grid">
    {
      projects.map((project) => (
        <article
          class="project-card fade-in-item"
          style={`--accent: ${project.data.accent ?? '#6366f1'}`}
        >
          {project.data.image && (
            <img
              class="project-shot"
              src={project.data.image}
              alt={`Captura de ${project.data.name}`}
              loading="lazy"
            />
          )}

          <div class="project-body">
            <div class="project-head">
              <span class="project-icon" aria-hidden={!project.data.icon}>
                {project.data.icon ? (
                  <img
                    src={project.data.icon}
                    alt={`Logo de ${project.data.name}`}
                  />
                ) : (
                  project.data.name.charAt(0)
                )}
              </span>
              <div class="project-id">
                <h2 class="project-name">{project.data.name}</h2>
                <p class="project-tagline">{project.data.tagline}</p>
              </div>
              <a
                href={project.data.repo}
                target="_blank"
                rel="noopener noreferrer"
                class="project-github"
                aria-label={`${project.data.name} en GitHub`}
              >
                GitHub ↗
              </a>
            </div>

            <p class="project-desc">{project.data.product}</p>

            <div class="project-pills">
              {project.data.stack.map((item: string) => (
                <TagPill label={item} />
              ))}
            </div>

            <details class="project-more">
              <summary>Ver detalles</summary>
              <div class="project-more-body">
                <p class="project-tech">{project.data.technical}</p>
                {project.data.url && (
                  <a
                    href={project.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="project-cta"
                  >
                    Probar {project.data.name} →
                  </a>
                )}
              </div>
            </details>
          </div>
        </article>
      ))
    }
  </div>
</BaseLayout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(22rem, 1fr));
    gap: 1.25rem;
    align-items: start;
  }

  .project-card {
    border: 1px solid var(--color-border);
    border-radius: 0.85rem;
    overflow: hidden;
    background-color: var(--color-bg);
    transition:
      border-color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }
  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: 0 10px 28px -14px
      color-mix(in oklab, var(--accent) 55%, transparent);
  }

  .project-shot {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-bottom: 1px solid var(--color-border);
  }

  .project-body {
    padding: 1.4rem;
  }

  .project-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .project-icon {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    flex-shrink: 0;
    border-radius: 0.6rem;
    background-color: var(--accent);
    color: #fff;
    font-size: 1.05rem;
    font-weight: 700;
    overflow: hidden;
  }
  .project-icon:has(img) {
    background-color: #fff;
    border: 1px solid var(--color-border);
    padding: 5px;
  }
  .project-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .project-id {
    flex: 1;
    min-width: 0;
  }

  .project-name {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
  }

  .project-tagline {
    font-size: 0.83rem;
    color: var(--accent);
    font-weight: 500;
    margin: 0.15rem 0 0;
    line-height: 1.4;
  }

  .project-github {
    flex-shrink: 0;
    align-self: flex-start;
    font-size: 0.75rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .project-github:hover {
    color: var(--accent);
  }

  .project-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0.9rem 0 0;
  }

  .project-pills {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .project-more {
    margin-top: 1.1rem;
  }
  .project-more summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
    transition: opacity 150ms ease;
  }
  .project-more summary::-webkit-details-marker {
    display: none;
  }
  .project-more summary::after {
    content: '▸';
    transition: transform 150ms ease;
  }
  .project-more[open] summary::after {
    transform: rotate(90deg);
  }
  .project-more summary:hover {
    opacity: 0.75;
  }

  .project-more-body {
    margin-top: 0.85rem;
    padding-top: 0.85rem;
    border-top: 1px solid var(--color-border);
  }

  .project-tech {
    font-size: 0.8125rem;
    color: var(--color-muted);
    line-height: 1.65;
    margin: 0;
  }

  .project-cta {
    display: inline-flex;
    align-items: center;
    margin-top: 1rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    background-color: var(--accent);
    color: #fff;
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    transition:
      opacity 150ms ease,
      transform 150ms ease;
  }
  .project-cta:hover {
    opacity: 0.9;
    transform: translateX(2px);
  }
</style>
