---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CardList from '../components/CardList.astro';
import TagPill from '../components/TagPill.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) =>
    a.data.order - b.data.order || a.data.name.localeCompare(b.data.name),
);
---

<BaseLayout
  title="Proyectos — notdefined.dev"
  description="Proyectos y experimentos de Adrian Castillo."
>
  <PageHeader
    label="Trabajo"
    title="Proyectos"
    description="Cosas que construyo, experimento o sigo desarrollando."
  />

  <CardList>
    {
      projects.map((project) => (
        <li class="card-list-item project-item fade-in-item">
          <div class="project-header">
            <div class="project-name-row">
              <h2 class="project-name">{project.data.name}</h2>
              <span class={`status status-${project.data.status}`}>
                {project.data.status}
              </span>
            </div>
            <div class="project-links">
              {project.data.url && (
                <a
                  href={project.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="project-link"
                >
                  sitio ↗
                </a>
              )}
              <a
                href={project.data.repo}
                target="_blank"
                rel="noopener noreferrer"
                class="project-link"
              >
                GitHub ↗
              </a>
            </div>
          </div>
          <p class="project-desc">{project.data.description}</p>
          <div class="project-footer">
            <TagPill label={project.data.lang} />
            {project.data.tags.map((tag: string) => (
              <TagPill label={tag} />
            ))}
          </div>
        </li>
      ))
    }
  </CardList>
</BaseLayout>

<style>
  .project-item {
    padding: 1.5rem;
  }

  .project-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.625rem;
  }

  .project-name-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .project-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .status {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 0.15em 0.55em;
    border-radius: 0.25rem;
    text-transform: lowercase;
  }

  .status-activo {
    background-color: oklch(92% 0.06 145);
    color: oklch(38% 0.12 145);
    border: 1px solid oklch(82% 0.09 145);
  }

  .status-mantenimiento {
    background-color: oklch(94% 0.04 95);
    color: oklch(40% 0.09 95);
    border: 1px solid oklch(84% 0.06 95);
  }

  .status-pausado {
    background-color: oklch(93% 0.01 250);
    color: oklch(38% 0.01 250);
    border: 1px solid oklch(84% 0.01 250);
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .project-link {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .project-link:hover {
    color: var(--color-accent);
  }

  .project-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0 0 0.875rem;
  }

  .project-footer {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
  }
</style>
