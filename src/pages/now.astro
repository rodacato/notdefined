---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const [current] = (await getCollection('now')).sort(
  (a, b) => b.data.updatedAt.valueOf() - a.data.updatedAt.valueOf(),
);

if (!current) {
  throw new Error('No existe contenido en src/content/now/.');
}

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Ahora — notdefined.dev"
  description="En qué está trabajando Adrian Castillo en este momento."
>
  <PageHeader
    label="Ahora"
    title="¿Qué estoy haciendo?"
    description="Una snapshot de lo que ocupa mi tiempo. Actualizo esto cuando algo cambia."
  />

  <div class="now-content">
    <section>
      <h2 class="section-title">Construyendo</h2>
      <ul class="now-list">
        {current.data.building.map((item: string) => <li set:html={item} />)}
      </ul>
    </section>

    <section>
      <h2 class="section-title">Explorando</h2>
      <ul class="now-list">
        {current.data.exploring.map((item: string) => <li>{item}</li>)}
      </ul>
    </section>

    <section>
      <h2 class="section-title">Escribiendo sobre</h2>
      <ul class="now-list">
        {current.data.writing.map((item: string) => <li>{item}</li>)}
      </ul>
    </section>
  </div>

  <p class="updated">
    Última actualización: {formatDate(current.data.updatedAt)}
  </p>
</BaseLayout>

<style>
  .now-content {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .section-title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.875rem;
    opacity: 0.7;
  }

  .now-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .now-list li {
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
    padding-left: 1rem;
    position: relative;
  }

  .now-list li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--color-muted);
    opacity: 0.5;
  }

  .updated {
    margin-top: 3rem;
    font-size: 0.75rem;
    color: var(--color-muted);
    opacity: 0.6;
  }
</style>
