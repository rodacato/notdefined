---
// El layout del "nivel secreto" (/guias): el negativo del sitio. Nav y footer
// propios, mínimos, en oscuro — el chrome claro de BaseLayout no existe aquí.
import '../styles/global.css';
import { siteProfile } from '../data/site';
import Analytics from '../components/Analytics.astro';
import ConsentBanner from '../components/ConsentBanner.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Nivel secreto de notdefined.dev' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/logo.png', Astro.site);
---

<!doctype html>
<html lang="es" class="h-full realm-html">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/logo.png" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="notdefined.dev RSS"
      href="/rss.xml"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <Analytics />
  </head>
  <body class="flex min-h-full flex-col realm-body">
    <div class="realm-scanlines" aria-hidden="true"></div>

    <header class="realm-header">
      <div
        class="mx-auto flex w-full max-w-5xl items-center justify-between px-6 py-4"
      >
        <a href="/guias/" class="realm-brand" data-text="notdefined">
          notdefined<span class="realm-cursor">_</span>
        </a>
        <nav class="realm-nav">
          <a href="/" class="realm-exit">← volver a la superficie</a>
        </nav>
      </div>
      <div class="realm-header-line" aria-hidden="true"></div>
    </header>

    <main class="mx-auto w-full max-w-5xl flex-1 px-6 py-10 md:py-14">
      <slot />
    </main>

    <footer class="realm-footer">
      <div
        class="mx-auto flex w-full max-w-5xl items-center justify-between gap-4 px-6 py-6"
      >
        <p class="realm-foot-text">
          © {new Date().getFullYear()}
          {siteProfile.name} · nivel secreto
        </p>
        <p class="realm-foot-code" title="ya estás dentro">
          ↑ ↑ ↓ ↓ ← → ← → B A
        </p>
      </div>
    </footer>

    <ConsentBanner />
  </body>
</html>

<style is:global>
  .realm-html {
    background: #0a0e10;
  }
  .realm-body {
    background:
      radial-gradient(
        120% 60% at 50% -10%,
        rgba(127, 216, 166, 0.06),
        transparent 60%
      ),
      #0a0e10;
    color: #eef3f2;
  }

  /* CRT sutil: scanlines casi imperceptibles sobre toda la capa. */
  .realm-scanlines {
    position: fixed;
    inset: 0;
    z-index: 50;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.014) 0 1px,
      transparent 1px 3px
    );
  }

  .realm-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 14, 16, 0.82);
    backdrop-filter: blur(10px);
  }
  .realm-header-line {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(127, 216, 166, 0.45),
      transparent
    );
  }

  .realm-brand {
    position: relative;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #eef3f2;
    text-decoration: none;
  }
  .realm-cursor {
    color: #7fd8a6;
    animation: realm-blink 1.1s steps(1) infinite;
  }
  @keyframes realm-blink {
    50% {
      opacity: 0;
    }
  }

  /* Glitch RGB-split, esporádico y breve: casi todo el ciclo está quieto. */
  .realm-glitch {
    position: relative;
  }
  .realm-glitch::before,
  .realm-glitch::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
  }
  .realm-glitch::before {
    color: #ff5f8f;
    animation: realm-glitch-a 7s infinite steps(1);
  }
  .realm-glitch::after {
    color: #58c7f3;
    animation: realm-glitch-b 7s infinite steps(1);
  }
  @keyframes realm-glitch-a {
    0%,
    93.8%,
    95.4%,
    100% {
      opacity: 0;
      transform: none;
      clip-path: none;
    }
    94% {
      opacity: 0.75;
      transform: translate(-2px, 1px);
      clip-path: inset(15% 0 55% 0);
    }
    94.7% {
      opacity: 0.75;
      transform: translate(2px, -1px);
      clip-path: inset(60% 0 12% 0);
    }
  }
  @keyframes realm-glitch-b {
    0%,
    93.8%,
    95.4%,
    100% {
      opacity: 0;
      transform: none;
      clip-path: none;
    }
    94.2% {
      opacity: 0.75;
      transform: translate(2px, -1px);
      clip-path: inset(48% 0 30% 0);
    }
    94.9% {
      opacity: 0.75;
      transform: translate(-2px, 1px);
      clip-path: inset(8% 0 70% 0);
    }
  }

  .realm-nav {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }
  .realm-exit {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: #8fa39d;
    text-decoration: none;
    transition: color 150ms ease;
  }
  .realm-exit:hover {
    color: #7fd8a6;
  }

  .realm-footer {
    border-top: 1px solid #1e2a2c;
  }
  .realm-foot-text {
    font-size: 0.78rem;
    color: #8fa39d;
    margin: 0;
  }
  .realm-foot-code {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    color: #7fd8a6;
    opacity: 0.55;
    margin: 0;
    cursor: help;
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .realm-cursor {
      animation: none;
    }
    .realm-glitch::before,
    .realm-glitch::after {
      animation: none;
      opacity: 0;
    }
  }
</style>
