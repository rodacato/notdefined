---
import '../styles/global.css';
import { siteProfile } from '../data/site';
import Analytics from '../components/Analytics.astro';
import ConsentBanner from '../components/ConsentBanner.astro';

interface Props {
  title: string;
  description?: string;
  width?: 'default' | 'wide';
  hideSearch?: boolean;
}

const {
  title,
  description = 'Sitio personal y blog de Adrian Castillo',
  width = 'default',
  hideSearch = false,
} = Astro.props;
const maxWidth = width === 'wide' ? 'max-w-5xl' : 'max-w-3xl';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/logo.png', Astro.site);
---

<!doctype html>
<html lang="es" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/logo.png" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="notdefined.dev RSS"
      href="/rss.xml"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <Analytics />
  </head>
  <body class="flex min-h-full flex-col">
    <div class="cursor-glow" aria-hidden="true"></div>
    <header class="site-header">
      <div
        class:list={[
          'mx-auto flex w-full items-center justify-between px-6 py-4',
          maxWidth,
        ]}
      >
        <a href="/" class="brand">
          <img src="/logo.png" alt="notdefined.dev logo" class="brand-logo" />
          <span class="brand-name"
            >notdefined<span class="cursor-blink">_</span></span
          >
        </a>
        {
          !hideSearch && (
            <form
              action="/search/"
              method="get"
              role="search"
              class="header-search"
            >
              <svg
                class="header-search-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                aria-hidden="true"
              >
                <circle cx="11" cy="11" r="7" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
              </svg>
              <input
                type="search"
                name="q"
                class="header-search-input"
                placeholder="Buscar…"
                aria-label="Buscar en el sitio"
                autocomplete="off"
              />
            </form>
          )
        }
        <nav class="flex items-center gap-5">
          <a href="/blog/" class="nav-link">Blog</a>
          <a href="/til/" class="nav-link">TIL</a>
          <a href="/projects/" class="nav-link">Proyectos</a>
          <a href="/about/" class="nav-link">About</a>
          {
            !hideSearch && (
              <a
                href="/search/"
                class="nav-link nav-search-mobile"
                aria-label="Buscar"
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  aria-hidden="true"
                >
                  <circle cx="11" cy="11" r="7" />
                  <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
              </a>
            )
          }
        </nav>
      </div>
      <div class="header-accent-line" aria-hidden="true"></div>
    </header>

    <main
      class:list={['mx-auto w-full flex-1 px-6 py-12 md:py-16', maxWidth]}
      style="position: relative; z-index: 1;"
    >
      <slot />
    </main>

    <footer class="site-footer" style="position: relative; z-index: 1;">
      <div class:list={['mx-auto w-full px-6 py-6', maxWidth]}>
        <div class="footer-inner">
          <div class="footer-links">
            <p class="footer-text">
              © {new Date().getFullYear()}
              {siteProfile.name}
            </p>
            <a href="/about/" class="footer-nav-link">About</a>
            <a href="/cv/" class="footer-nav-link">CV</a>
            <a href="/como-escribo/" class="footer-nav-link">Cómo escribo</a>
          </div>
          <div class="footer-right">
            <span
              class="footer-konami"
              title="↑ ↑ ↓ ↓ ← → ← → B A"
              aria-label="Konami code soportado">konami code supported</span
            >
            <a href="/rss.xml" class="rss-link" title="Feed RSS">RSS</a>
          </div>
        </div>
      </div>
    </footer>

    <ConsentBanner />
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: oklch(99.5% 0.002 250 / 0.8);
    backdrop-filter: blur(0px);
    transition:
      backdrop-filter 0.3s ease,
      background-color 0.3s ease;
  }

  .site-header.is-scrolled {
    backdrop-filter: blur(12px);
    background-color: oklch(99.5% 0.002 250 / 0.92);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition: opacity 150ms ease;
  }
  .brand:hover {
    opacity: 0.7;
  }

  .brand-logo {
    width: 26px;
    height: 26px;
    border-radius: 6px;
    display: block;
  }

  .brand-name {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .nav-link {
    font-size: 0.875rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .nav-link:hover {
    color: var(--color-text);
  }

  .header-search {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex: 0 1 14rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background-color: var(--color-surface);
    transition: border-color 150ms ease;
  }
  .header-search:focus-within {
    border-color: var(--color-accent);
  }

  .header-search-icon {
    width: 0.9rem;
    height: 0.9rem;
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .header-search-input {
    width: 100%;
    border: none;
    background: transparent;
    outline: none;
    font-family: inherit;
    font-size: 0.82rem;
    color: var(--color-text);
  }
  .header-search-input::placeholder {
    color: var(--color-muted);
    opacity: 0.8;
  }
  .header-search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .nav-search-mobile {
    display: none;
  }
  .nav-search-mobile svg {
    width: 1.05rem;
    height: 1.05rem;
  }

  @media (max-width: 640px) {
    .header-search {
      display: none;
    }
    .nav-search-mobile {
      display: inline-flex;
      align-items: center;
    }
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-konami {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    opacity: 0.55;
    cursor: help;
    transition: opacity 150ms ease;
  }
  .footer-konami:hover {
    opacity: 0.9;
  }
  @media (max-width: 640px) {
    .footer-konami {
      display: none;
    }
  }

  .footer-text {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .footer-nav-link {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .footer-nav-link:hover {
    color: var(--color-text);
  }

  .rss-link {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 150ms ease;
  }
  .rss-link:hover {
    color: var(--color-accent);
  }
</style>

<script>
  // Cursor glow
  const glow = document.querySelector('.cursor-glow') as HTMLElement | null;
  if (glow && window.matchMedia('(pointer: fine)').matches) {
    document.addEventListener('mousemove', (e) => {
      glow.style.left = `${e.clientX}px`;
      glow.style.top = `${e.clientY}px`;
      if (!glow.classList.contains('is-visible')) {
        glow.classList.add('is-visible');
      }
    });
    document.addEventListener('mouseleave', () => {
      glow.classList.remove('is-visible');
    });
  }

  // Scroll-aware header blur
  const header = document.querySelector('.site-header');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 10);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Staggered fade-in on scroll
  const items = document.querySelectorAll('.fade-in-item');
  if (items.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 },
    );
    items.forEach((item, i) => {
      (item as HTMLElement).style.transitionDelay = `${i * 50}ms`;
      observer.observe(item);
    });
  }

  // Tag pills staggered landing
  document
    .querySelectorAll('.fade-in-item.is-visible .tag-pill, .tag-pill')
    .forEach((pill, i) => {
      (pill as HTMLElement).style.animationDelay = `${i * 60}ms`;
      pill.classList.add('is-landed');
    });

  // Konami code → nivel secreto (/guias). Puerta dramática, no la única:
  // /guias también está en el pie y es públicamente descubrible.
  const KONAMI = [
    'ArrowUp',
    'ArrowUp',
    'ArrowDown',
    'ArrowDown',
    'ArrowLeft',
    'ArrowRight',
    'ArrowLeft',
    'ArrowRight',
    'b',
    'a',
  ];
  let konamiPos = 0;
  const reduceMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches;

  function enterRealm() {
    if (window.location.pathname.startsWith('/guias')) return;
    if (reduceMotion) {
      window.location.href = '/guias/';
      return;
    }
    const veil = document.createElement('div');
    veil.setAttribute('aria-hidden', 'true');
    veil.style.cssText =
      'position:fixed;inset:0;z-index:9999;background:#0a0e10;opacity:0;' +
      'transition:opacity 420ms ease;pointer-events:none;';
    document.body.appendChild(veil);
    requestAnimationFrame(() => {
      veil.style.opacity = '1';
    });
    window.setTimeout(() => {
      window.location.href = '/guias/';
    }, 440);
  }

  window.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement | null;
    if (
      target &&
      (target.tagName === 'INPUT' ||
        target.tagName === 'TEXTAREA' ||
        target.isContentEditable)
    ) {
      return;
    }
    const key = e.key.length === 1 ? e.key.toLowerCase() : e.key;
    if (key === KONAMI[konamiPos]) {
      konamiPos += 1;
      if (konamiPos === KONAMI.length) {
        konamiPos = 0;
        enterRealm();
      }
    } else {
      konamiPos = key === KONAMI[0] ? 1 : 0;
    }
  });

  // Parallax sections (landing page only)
  const parallaxSections = document.querySelectorAll('[data-parallax]');
  if (parallaxSections.length > 0) {
    window.addEventListener(
      'scroll',
      () => {
        const scrollY = window.scrollY;
        parallaxSections.forEach((section) => {
          const speed = parseFloat(
            (section as HTMLElement).dataset.parallax || '0.03',
          );
          const rect = (section as HTMLElement).getBoundingClientRect();
          const offset = (rect.top + scrollY - window.innerHeight / 2) * speed;
          (section as HTMLElement).style.transform = `translateY(${offset}px)`;
        });
      },
      { passive: true },
    );
  }
</script>
