---
import '../styles/global.css';
import { siteProfile } from '../data/site';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Sitio personal y blog de Adrian Castillo' } =
  Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/logo.png', Astro.site);
---

<!doctype html>
<html lang="es" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/logo.png" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="notdefined.dev RSS"
      href="/rss.xml"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
  </head>
  <body class="flex min-h-full flex-col">
    <div class="cursor-glow" aria-hidden="true"></div>
    <header class="site-header">
      <div
        class="mx-auto flex w-full max-w-3xl items-center justify-between px-6 py-4"
      >
        <a href="/" class="brand">
          <img src="/logo.png" alt="notdefined.dev logo" class="brand-logo" />
          <span class="brand-name"
            >notdefined<span class="cursor-blink">_</span></span
          >
        </a>
        <nav class="flex items-center gap-5">
          <a href="/blog/" class="nav-link">Blog</a>
          <a href="/til/" class="nav-link">TIL</a>
          <a href="/projects/" class="nav-link">Proyectos</a>
          <a href="/about/" class="nav-link">About</a>
          <a href="/search/" class="nav-link">Buscar</a>
        </nav>
      </div>
      <div class="header-accent-line" aria-hidden="true"></div>
    </header>

    <main class="mx-auto w-full max-w-3xl flex-1 px-6 py-12 md:py-16" style="position: relative; z-index: 1;">
      <slot />
    </main>

    <footer class="site-footer" style="position: relative; z-index: 1;">
      <div class="mx-auto w-full max-w-3xl px-6 py-6">
        <div class="footer-inner">
          <div class="footer-links">
            <p class="footer-text">
              © {new Date().getFullYear()}
              {siteProfile.name}
            </p>
            <a href="/now/" class="footer-nav-link">Ahora</a>
            <a href="/about/" class="footer-nav-link">About</a>
          </div>
          <a href="/rss.xml" class="rss-link" title="Feed RSS">RSS</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: oklch(99.5% 0.002 250 / 0.8);
    backdrop-filter: blur(0px);
    transition:
      backdrop-filter 0.3s ease,
      background-color 0.3s ease;
  }

  .site-header.is-scrolled {
    backdrop-filter: blur(12px);
    background-color: oklch(99.5% 0.002 250 / 0.92);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition: opacity 150ms ease;
  }
  .brand:hover {
    opacity: 0.7;
  }

  .brand-logo {
    width: 26px;
    height: 26px;
    border-radius: 6px;
    display: block;
  }

  .brand-name {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .nav-link {
    font-size: 0.875rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .nav-link:hover {
    color: var(--color-text);
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-text {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .footer-nav-link {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .footer-nav-link:hover {
    color: var(--color-text);
  }

  .rss-link {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 150ms ease;
  }
  .rss-link:hover {
    color: var(--color-accent);
  }
</style>

<script>
  // Cursor glow
  const glow = document.querySelector('.cursor-glow') as HTMLElement | null;
  if (glow && window.matchMedia('(pointer: fine)').matches) {
    document.addEventListener('mousemove', (e) => {
      glow.style.left = `${e.clientX}px`;
      glow.style.top = `${e.clientY}px`;
      if (!glow.classList.contains('is-visible')) {
        glow.classList.add('is-visible');
      }
    });
    document.addEventListener('mouseleave', () => {
      glow.classList.remove('is-visible');
    });
  }

  // Scroll-aware header blur
  const header = document.querySelector('.site-header');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 10);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Staggered fade-in on scroll
  const items = document.querySelectorAll('.fade-in-item');
  if (items.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 },
    );
    items.forEach((item, i) => {
      (item as HTMLElement).style.transitionDelay = `${i * 50}ms`;
      observer.observe(item);
    });
  }

  // Tag pills staggered landing
  document.querySelectorAll('.fade-in-item.is-visible .tag-pill, .tag-pill').forEach((pill, i) => {
    (pill as HTMLElement).style.animationDelay = `${i * 60}ms`;
    pill.classList.add('is-landed');
  });

  // Parallax sections (landing page only)
  const parallaxSections = document.querySelectorAll('[data-parallax]');
  if (parallaxSections.length > 0) {
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      parallaxSections.forEach((section) => {
        const speed = parseFloat((section as HTMLElement).dataset.parallax || '0.03');
        const rect = (section as HTMLElement).getBoundingClientRect();
        const offset = (rect.top + scrollY - window.innerHeight / 2) * speed;
        (section as HTMLElement).style.transform = `translateY(${offset}px)`;
      });
    }, { passive: true });
  }
</script>
