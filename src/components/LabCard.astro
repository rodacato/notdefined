---
interface Props {
  href: string;
  title?: string;
  blurb?: string;
  meta?: string;
  cta?: string;
}

const {
  href,
  title = 'Pruébalo en el lab',
  blurb,
  meta,
  cta = 'Abrir el lab →',
} = Astro.props;
---

<aside class="lab-card">
  <a href={href} class="lab-card-link">
    <span class="lab-card-eyebrow">Lab interactivo</span>
    <strong class="lab-card-title">{title}</strong>
    {blurb && <span class="lab-card-blurb">{blurb}</span>}
    {meta && <span class="lab-card-meta">{meta}</span>}
    <span class="lab-card-cta">{cta}</span>
  </a>
</aside>

<style>
  .lab-card {
    margin: 3rem 0 0;
  }
  .lab-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.6rem 1.8rem;
    border: 1px solid
      color-mix(in oklab, var(--color-accent) 30%, var(--color-border));
    border-radius: 0.9rem;
    background: color-mix(in oklab, var(--color-accent) 7%, var(--color-bg));
    box-shadow: 0 14px 36px -22px
      color-mix(in oklab, var(--color-accent) 70%, transparent);
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease,
      transform 150ms ease;
  }
  .lab-card-link:hover {
    border-color: var(--color-accent);
    box-shadow: 0 18px 40px -20px
      color-mix(in oklab, var(--color-accent) 75%, transparent);
    transform: translateY(-2px);
  }
  .lab-card-eyebrow {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.55rem;
  }
  .lab-card-title {
    display: block;
    font-size: 1.3rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 0.4rem;
  }
  .lab-card-blurb {
    display: block;
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.55;
    margin-bottom: 0.9rem;
  }
  .lab-card-meta {
    display: block;
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }
  .lab-card-cta {
    display: inline-flex;
    align-items: center;
    font-weight: 600;
    font-size: 0.88rem;
    color: #fff;
    background-color: var(--color-accent);
    padding: 0.55rem 1.05rem;
    border-radius: 0.55rem;
  }
</style>
