---
import { analytics } from '../data/site';

const enabled = Boolean(analytics.gaId) && import.meta.env.PROD;
---

{
  enabled && (
    <div id="consent-bar" class="consent-bar" hidden>
      <span class="consent-icon" aria-hidden="true">
        🍪
      </span>
      <p class="consent-text">
        Este sitio usa cookies para mejorar tu experiencia.
      </p>
      <div class="consent-actions">
        <button
          id="consent-reject"
          class="consent-btn consent-btn-ghost"
          type="button"
        >
          Rechazar
        </button>
        <button id="consent-accept" class="consent-btn" type="button">
          Aceptar
        </button>
      </div>
    </div>
  )
}

<style>
  .consent-bar {
    position: fixed;
    bottom: 1.5rem;
    left: 1.5rem;
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    width: min(26rem, calc(100vw - 3rem));
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background-color: var(--color-surface);
    box-shadow: 0 12px 34px oklch(0% 0 0 / 0.18);
    animation: consent-in 260ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes consent-in {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .consent-icon {
    flex-shrink: 0;
    font-size: 1.6rem;
    line-height: 1;
  }

  .consent-text {
    flex: 1;
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.35;
    color: var(--color-text);
  }

  .consent-actions {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .consent-btn {
    padding: 0.35rem 0.9rem;
    border: 1px solid var(--color-accent);
    border-radius: 999px;
    background-color: var(--color-accent);
    color: white;
    font-family: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    transition: opacity 150ms ease;
  }
  .consent-btn:hover {
    opacity: 0.85;
  }

  .consent-btn-ghost {
    border-color: var(--color-border);
    background-color: transparent;
    color: var(--color-muted);
  }
  .consent-btn-ghost:hover {
    color: var(--color-text);
    opacity: 1;
  }

  @media (max-width: 460px) {
    .consent-bar {
      flex-wrap: wrap;
    }
    .consent-actions {
      width: 100%;
      justify-content: flex-end;
    }
  }
</style>

<script>
  const KEY = 'nd-consent';
  const bar = document.getElementById('consent-bar');

  let stored: string | null = null;
  try {
    stored = localStorage.getItem(KEY);
  } catch {
    stored = null;
  }
  if (bar && !stored) bar.hidden = false;

  function decide(value: 'granted' | 'denied') {
    try {
      localStorage.setItem(KEY, value);
    } catch {
      // storage bloqueado: la decisión no persiste, se vuelve a preguntar
    }
    if (value === 'granted') {
      const gtag = (window as Window & { gtag?: (...args: unknown[]) => void })
        .gtag;
      if (typeof gtag === 'function') {
        gtag('consent', 'update', {
          ad_storage: 'granted',
          ad_user_data: 'granted',
          ad_personalization: 'granted',
          analytics_storage: 'granted',
        });
      }
    }
    if (bar) bar.hidden = true;
  }

  document
    .getElementById('consent-accept')
    ?.addEventListener('click', () => decide('granted'));
  document
    .getElementById('consent-reject')
    ?.addEventListener('click', () => decide('denied'));
</script>
